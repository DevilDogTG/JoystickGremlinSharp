<?xml version="1.0" encoding="UTF-8"?>
<!--
  SPDX-License-Identifier: GPL-3.0-only

  JoystickGremlinSharp — WiX v6 MSI Package Definition
  ======================================================
  UpgradeCode MUST NOT change between releases — it identifies this product family for upgrades.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <!-- ═══════════════════════════════════════════════════════════════════
       Package
       ═══════════════════════════════════════════════════════════════════ -->
  <Package
    Name="Joystick Gremlin Sharp"
    Manufacturer="DevilDogTG"
    Version="$(AppVersion)"
    UpgradeCode="{3BE7219A-DAE0-41D4-BDB3-E0530808F9C3}"
    Scope="perMachine"
    Compressed="yes">

    <!-- Clean in-place upgrades. Prevents downgrade. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of Joystick Gremlin Sharp is already installed." />

    <!-- Single CAB embedded in the MSI. -->
    <MediaTemplate EmbedCab="yes" />

    <!-- ARP (Add/Remove Programs) enrichment -->
    <Property Id="ARPURLINFOABOUT"  Value="https://github.com/DevilDogTG/JoystickGremlinSharp" />
    <Property Id="ARPHELPLINK"      Value="https://github.com/DevilDogTG/JoystickGremlinSharp/issues" />
    <Property Id="ARPCOMMENTS"      Value="A C#/.NET 10 rewrite of JoystickGremlin. Map joystick inputs to virtual vJoy outputs." />
    <Property Id="ARPPRODUCTICON"   Value="JgsIcon.ico" />
    <Icon     Id="JgsIcon.ico"      SourceFile="$(MSBuildThisFileDirectory)..\src\JoystickGremlin.App\Assets\icon.ico" />

    <!-- ── UI ──────────────────────────────────────────────────────────
         WixUI_Mondo provides:
           Welcome → License → Setup Type (Typical / Custom / Complete)
           Custom path: shows directory picker + feature tree
           Typical: installs to default dir with all features at Level≤1
    ───────────────────────────────────────────────────────────────────── -->
    <ui:WixUI Id="WixUI_Mondo" />

    <!-- License agreement shown in wizard -->
    <WixVariable Id="WixUILicenseRtf" Value="$(MSBuildThisFileDirectory)License.rtf" />

    <!-- Default install root shown in directory picker (Custom mode) -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <!-- ── Features ────────────────────────────────────────────────────
         Level 1  = selected in Typical + Custom
         Level 2  = optional; selected in Custom only (user can toggle)
         Level 0  = absent (disabled)
    ───────────────────────────────────────────────────────────────────── -->
    <Feature Id="MainApp"
             Title="Joystick Gremlin Sharp"
             Description="The application and all required files."
             Level="1"
             Absent="disallow">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <Feature Id="DesktopShortcutFeature"
             Title="Desktop Shortcut"
             Description="Create a shortcut on the Desktop."
             Level="1">
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

  </Package>

  <!-- ═══════════════════════════════════════════════════════════════════
       Directory layout
       ═══════════════════════════════════════════════════════════════════ -->
  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">

      <!-- Program Files\JoystickGremlinSharp  (x64 machine) -->
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="JoystickGremlinSharp" />
      </Directory>

      <!-- Desktop -->
      <Directory Id="DesktopFolder" />

      <!-- Start Menu\Programs\JoystickGremlinSharp -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppMenuFolder" Name="JoystickGremlinSharp" />
      </Directory>

    </Directory>
  </Fragment>

  <!-- ═══════════════════════════════════════════════════════════════════
       Application files  (harvested from publish dir via .wixproj)
       AppFiles ComponentGroup is generated by HarvestDirectory at build time.
       ═══════════════════════════════════════════════════════════════════ -->

  <!-- ═══════════════════════════════════════════════════════════════════
       Shortcuts
       ═══════════════════════════════════════════════════════════════════ -->
  <Fragment>

    <!-- Start Menu shortcut — always installed -->
    <Component Id="StartMenuShortcut" Directory="AppMenuFolder" Guid="*">
      <Shortcut Id="StartMenuSC"
                Name="Joystick Gremlin Sharp"
                Description="Map joystick inputs to virtual vJoy outputs."
                Target="[INSTALLFOLDER]JoystickGremlin.App.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="JgsIcon.ico" />
      <!-- Clean up the folder on uninstall -->
      <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
      <!-- Key path — required for every Component -->
      <RegistryValue Root="HKCU"
                     Key="Software\DevilDogTG\JoystickGremlinSharp"
                     Name="StartMenuShortcut"
                     Type="integer" Value="1"
                     KeyPath="yes" />
    </Component>

    <!-- Desktop shortcut — optional feature, selected by default -->
    <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="*">
      <Shortcut Id="DesktopSC"
                Name="Joystick Gremlin Sharp"
                Description="Map joystick inputs to virtual vJoy outputs."
                Target="[INSTALLFOLDER]JoystickGremlin.App.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="JgsIcon.ico" />
      <RegistryValue Root="HKCU"
                     Key="Software\DevilDogTG\JoystickGremlinSharp"
                     Name="DesktopShortcut"
                     Type="integer" Value="1"
                     KeyPath="yes" />
    </Component>

  </Fragment>

</Wix>
