<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="JoystickGremlin.App.App"
             xmlns:local="using:JoystickGremlin.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/icon.ico"
                      ToolTipText="Joystick Gremlin"
                      Clicked="TrayIcon_Clicked" />
        </TrayIcons>
    </TrayIcon.Icons>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#40FF6600"/>
        <SolidColorBrush x:Key="WarningForegroundBrush" Color="Orange"/>
    </Application.Resources>
</Application>