<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JoystickGremlin.App.ViewModels"
             xmlns:ew="using:JoystickGremlin.Core.EmuWheel"
             x:Class="JoystickGremlin.App.Views.SettingsPageView"
             x:DataType="vm:SettingsPageViewModel">

    <ScrollViewer>
        <StackPanel Margin="16" MaxWidth="520" Spacing="16">

            <TextBlock Text="Settings" FontWeight="SemiBold" FontSize="18"/>

            <StackPanel Spacing="4">
                <TextBlock Text="Profiles Folder Path"/>
                <TextBox Text="{Binding ProfilesFolderPath}" PlaceholderText="(default: %AppData%\JoystickGremlinSharp\profiles)"/>
            </StackPanel>

            <CheckBox Content="Start minimized to tray" IsChecked="{Binding StartMinimized}"/>

            <!-- ─── Live Input Display ─── -->
            <Border Padding="0,8,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Live Input Display" FontWeight="SemiBold" FontSize="15"/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="11">
                        Controls how often the Controller Setup page refreshes live input state.
                        Lower interval = higher refresh rate. Very low values (≤ 5 ms) may increase CPU usage noticeably.
                    </TextBlock>
                    <Grid ColumnDefinitions="*,120,Auto" RowDefinitions="Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0"
                                   Text="Update interval (ms)"
                                   VerticalAlignment="Center"/>
                        <NumericUpDown Grid.Column="1"
                                       Value="{Binding UiUpdateIntervalMs}"
                                       Minimum="1" Maximum="1000" Increment="5"
                                       FormatString="0"
                                       ToolTip.Tip="Live input refresh interval in milliseconds. 10 ms = ~100 Hz. Lower = smoother but more CPU."/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding UiUpdateHz}"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Opacity="0.8"/>
                    </Grid>
                    <Border Background="{StaticResource WarningBackgroundBrush}"
                            CornerRadius="4"
                            Padding="8,6"
                            IsVisible="{Binding UiUpdateHighFrequencyWarning}">
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="{StaticResource WarningForegroundBrush}">
                            ⚠️ Very high refresh rate (≤ 5 ms / ≥ 200 Hz). This may consume significant CPU resources, especially with multiple high-speed devices connected.
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ─── System Tray ─── -->
            <Border Padding="0,8,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="System Tray" FontWeight="SemiBold" FontSize="15"/>
                    <CheckBox Content="Start with Windows"
                              IsChecked="{Binding StartWithWindows}"
                              ToolTip.Tip="Register the application to launch automatically when you log in to Windows."/>
                    <CheckBox Content="Minimize to tray on close"
                              IsChecked="{Binding CloseToTray}"
                              ToolTip.Tip="Clicking the window close button (✕) hides the window to the system tray instead of exiting. Use the tray icon menu to exit."/>
                </StackPanel>
            </Border>

            <!-- ─── Auto-load Profiles ─── -->
            <Border Padding="0,8,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Spacing="10">

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Auto-load Profiles"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   VerticalAlignment="Center"/>
                        <CheckBox Content="Enabled"
                                  IsChecked="{Binding EnableAutoLoading}"
                                  VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="11">
                        When the mapped game becomes the active window, its profile is loaded automatically.
                        Use exact paths (C:/Games/game.exe) or regex patterns (.*MyGame.*). First match wins.
                    </TextBlock>

                    <!-- Mapping list header -->
                    <Grid ColumnDefinitions="*,*,60,65,70,80"
                          IsVisible="{Binding ProcessMappings.Count}">
                        <TextBlock Grid.Column="0" Text="Executable / Pattern" FontSize="11" FontWeight="SemiBold" Margin="2,0"/>
                        <TextBlock Grid.Column="1" Text="Profile"              FontSize="11" FontWeight="SemiBold" Margin="2,0"/>
                        <TextBlock Grid.Column="2" Text="On"                   FontSize="11" FontWeight="SemiBold" Margin="2,0" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="AutoStart"            FontSize="11" FontWeight="SemiBold" Margin="2,0" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="Stay Active"          FontSize="11" FontWeight="SemiBold" Margin="2,0" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="Actions"              FontSize="11" FontWeight="SemiBold" Margin="2,0" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Mapping rows -->
                    <ItemsControl ItemsSource="{Binding ProcessMappings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProcessMappingViewModel">
                                <Grid ColumnDefinitions="*,*,60,65,70,80"
                                      Margin="0,2">
                                    <!-- Executable / pattern -->
                                    <TextBox Grid.Column="0"
                                             Text="{Binding ExecutablePath}"
                                             PlaceholderText="C:/Games/game.exe"
                                             FontSize="11"
                                             Margin="2,0"/>
                                    <!-- Profile path + browse -->
                                    <Grid Grid.Column="1" ColumnDefinitions="*,26" Margin="2,0">
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding ProfilePath}"
                                                 PlaceholderText="profile.json"
                                                 FontSize="11"/>
                                        <Button Grid.Column="1"
                                                Content="…"
                                                Command="{Binding BrowseProfileCommand}"
                                                FontSize="11"
                                                Padding="2,0"
                                                ToolTip.Tip="Browse for profile file"/>
                                    </Grid>
                                    <!-- IsEnabled -->
                                    <CheckBox Grid.Column="2"
                                              IsChecked="{Binding IsEnabled}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    <!-- AutoStart -->
                                    <CheckBox Grid.Column="3"
                                              IsChecked="{Binding AutoStart}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    <!-- RemainActiveOnFocusLoss -->
                                    <CheckBox Grid.Column="4"
                                              IsChecked="{Binding RemainActiveOnFocusLoss}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ToolTip.Tip="Keep pipeline running when this game loses focus"/>
                                    <!-- Actions: ↑ ↓ 🗑 -->
                                    <StackPanel Grid.Column="5"
                                                Orientation="Horizontal"
                                                Spacing="2"
                                                HorizontalAlignment="Center">
                                        <Button Content="↑"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsPageViewModel)DataContext).MoveUpCommand}"
                                                CommandParameter="{Binding}"
                                                FontSize="11" Padding="4,2"
                                                ToolTip.Tip="Move up (higher priority)"/>
                                        <Button Content="↓"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsPageViewModel)DataContext).MoveDownCommand}"
                                                CommandParameter="{Binding}"
                                                FontSize="11" Padding="4,2"
                                                ToolTip.Tip="Move down (lower priority)"/>
                                        <Button Content="🗑"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsPageViewModel)DataContext).RemoveMappingCommand}"
                                                CommandParameter="{Binding}"
                                                FontSize="11" Padding="4,2"
                                                ToolTip.Tip="Remove this mapping"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="+ Add Mapping"
                            Command="{Binding AddMappingCommand}"
                            FontSize="12"
                            HorizontalAlignment="Left"/>

                </StackPanel>
            </Border>

            <!-- ─── Force Feedback Bridge ─── -->
            <Border Padding="0,8,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Spacing="10">

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Force Feedback Bridge"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   VerticalAlignment="Center"/>
                        <CheckBox Content="Enabled"
                                  IsChecked="{Binding EnableFfbBridge}"
                                  VerticalAlignment="Center"
                                  ToolTip.Tip="Forwards FFB commands from vJoy to your physical wheel via DirectInput."/>
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="11">
                        Bridges force feedback from a game (via vJoy) to your physical racing wheel.
                        Requires vJoy and a DirectInput-capable wheel (e.g. MOZA). Restart the pipeline after changing these settings.
                    </TextBlock>

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto"
                          RowSpacing="8" ColumnSpacing="12">

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="FFB vJoy Device ID"
                                   VerticalAlignment="Center"
                                   IsEnabled="{Binding EnableFfbBridge}"/>
                        <NumericUpDown Grid.Row="0" Grid.Column="1"
                                       Value="{Binding FfbVJoyDeviceId}"
                                       Minimum="1" Maximum="16" Increment="1"
                                       FormatString="0"
                                       IsEnabled="{Binding EnableFfbBridge}"
                                       ToolTip.Tip="vJoy device ID that the game writes FFB commands to (must match your vJoy configuration)."/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Gain %"
                                   VerticalAlignment="Center"
                                   IsEnabled="{Binding EnableFfbBridge}"/>
                        <NumericUpDown Grid.Row="1" Grid.Column="1"
                                       Value="{Binding FfbGainPercent}"
                                       Minimum="0" Maximum="200" Increment="5"
                                       FormatString="0"
                                       IsEnabled="{Binding EnableFfbBridge}"
                                       ToolTip.Tip="Output gain applied to all force effects. 100 = pass-through, 0 = no force, 200 = double."/>

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Wheel GUID"
                                   VerticalAlignment="Center"
                                   IsEnabled="{Binding EnableFfbBridge}"/>
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding FfbWheelInstanceGuid}"
                                 PlaceholderText="(auto-detect first MOZA device)"
                                 IsEnabled="{Binding EnableFfbBridge}"
                                 ToolTip.Tip="DirectInput instance GUID of the target wheel. Leave empty to auto-detect the first MOZA device found."/>

                        <!-- Status is always visible regardless of enabled state -->
                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="Bridge Status"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding FfbBridgeStatus}"
                                   VerticalAlignment="Center"
                                   Opacity="0.7"
                                   FontStyle="Italic"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ─── Wheel Emulation (EmuWheel) ─── -->
            <Border Padding="0,8,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Spacing="10">

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Wheel Emulation"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   VerticalAlignment="Center"/>
                        <CheckBox Content="Enabled"
                                  IsChecked="{Binding EnableEmuWheel}"
                                  VerticalAlignment="Center"
                                  ToolTip.Tip="Enables the EmuWheel backend. When a profile containing emuwheel-* actions is started, the selected vJoy slot is spoofed to appear as the chosen wheel model."/>
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="11">
                        Spoofs a vJoy device's USB identity to appear as a real steering wheel.
                        Requires administrator privileges to write registry entries.
                        Disable Steam Input per game (Properties → Controller → Disable Steam Input) for The Crew 2 and Forza Horizon 4.
                    </TextBlock>

                    <!-- Admin warning: shown when EmuWheel is enabled but process is not elevated -->
                    <Border Background="{StaticResource WarningBackgroundBrush}"
                            CornerRadius="4"
                            Padding="10,6"
                            IsVisible="{Binding EmuWheelAdminWarning}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="⚠️" VerticalAlignment="Center"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="{StaticResource WarningForegroundBrush}"
                                       FontSize="12"
                                       Text="Not running as administrator — EmuWheel identity spoofing will not work. Start the app with 'Run as administrator', or click Start on a profile that uses EmuWheel to be prompted automatically."/>
                        </StackPanel>
                    </Border>

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto"
                          RowSpacing="8" ColumnSpacing="12">

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="EmuWheel vJoy Device ID"
                                   VerticalAlignment="Center"
                                   IsEnabled="{Binding EnableEmuWheel}"
                                   ToolTip.Tip="The vJoy device slot (1–16) that will be spoofed as a wheel. Use a slot different from your generic vJoy device ID."/>
                        <NumericUpDown Grid.Row="0" Grid.Column="1"
                                       Value="{Binding EmuWheelVJoyDeviceId}"
                                       Minimum="1" Maximum="16" Increment="1"
                                       FormatString="0"
                                       IsEnabled="{Binding EnableEmuWheel}"
                                       ToolTip.Tip="The vJoy device slot (1–16) that will be spoofed as a wheel. Use a slot different from your generic vJoy device ID."/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Wheel Model"
                                   VerticalAlignment="Center"
                                   IsEnabled="{Binding EnableEmuWheel}"
                                   ToolTip.Tip="The wheel identity to spoof. Choose a model supported by your target game's whitelist."/>
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  ItemsSource="{Binding AvailableWheelModels}"
                                  SelectedItem="{Binding SelectedWheelModelInfo}"
                                  IsEnabled="{Binding EnableEmuWheel}"
                                  HorizontalAlignment="Stretch"
                                  ToolTip.Tip="The wheel identity to spoof. Choose a model supported by your target game's whitelist.">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="ew:WheelModelInfo">
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                    </Grid>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>


