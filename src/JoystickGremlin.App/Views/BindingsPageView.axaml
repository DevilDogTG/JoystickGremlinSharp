<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JoystickGremlin.App.ViewModels"
             xmlns:actions="using:JoystickGremlin.Core.Actions"
             x:Class="JoystickGremlin.App.Views.BindingsPageView"
             x:DataType="vm:BindingsPageViewModel">

    <Grid ColumnDefinitions="200,180,*">

        <!-- ─── Device List ─── -->
        <DockPanel Grid.Column="0">
            <Border DockPanel.Dock="Top"
                    Padding="8,6"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <TextBlock Text="Devices" FontWeight="SemiBold" FontSize="13"/>
            </Border>

            <ListBox ItemsSource="{Binding Devices}"
                     SelectedItem="{Binding SelectedDevice}"
                     BorderThickness="0,0,1,0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:DeviceViewModel">
                        <TextBlock Text="{Binding Name}"
                                   TextWrapping="Wrap"
                                   Margin="4,4"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- ─── Input List ─── -->
        <DockPanel Grid.Column="1">
            <Border DockPanel.Dock="Top"
                    Padding="8,6"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <TextBlock Text="Inputs" FontWeight="SemiBold" FontSize="13"/>
            </Border>

            <ListBox ItemsSource="{Binding AvailableInputs}"
                     SelectedItem="{Binding SelectedInput}"
                     BorderThickness="0,0,1,0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:InputDescriptorViewModel">
                        <TextBlock Text="{Binding DisplayName}" Margin="4,4"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- ─── Bindings Editor ─── -->
        <DockPanel Grid.Column="2">

            <!-- Add-action toolbar -->
            <Border DockPanel.Dock="Top"
                    Padding="8,4"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <ComboBox ItemsSource="{Binding AvailableActionTypes}"
                              SelectedItem="{Binding SelectedNewActionType}"
                              MinWidth="140"
                              IsEnabled="{Binding HasProfile}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="actions:IActionDescriptor">
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="+ Add"
                            Command="{Binding AddActionCommand}"
                            FontSize="12"/>
                    <Button Content="− Remove"
                            Command="{Binding RemoveActionCommand}"
                            FontSize="12"/>
                    <Button Content="▲"
                            Command="{Binding MoveUpCommand}"
                            FontSize="12"
                            ToolTip.Tip="Move action up"/>
                    <Button Content="▼"
                            Command="{Binding MoveDownCommand}"
                            FontSize="12"
                            ToolTip.Tip="Move action down"/>
                </StackPanel>
            </Border>

            <!-- Bound action list + config form -->
            <Grid RowDefinitions="180,*">

                <!-- Action list -->
                <ListBox Grid.Row="0"
                         ItemsSource="{Binding BoundActions}"
                         SelectedItem="{Binding SelectedBoundAction}"
                         BorderThickness="0,0,0,1">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:BoundActionViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,3">
                                <TextBlock Text="{Binding ActionName}"
                                           FontWeight="SemiBold"
                                           MinWidth="120"/>
                                <TextBlock Text="{Binding ConfigSummary}"
                                           Opacity="0.6"
                                           FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Config form / inherited-override panel -->
                <ScrollViewer Grid.Row="1">
                    <StackPanel Margin="12" Spacing="10">

                        <!-- Configure Action form -->
                        <StackPanel Spacing="10" IsVisible="{Binding ShowConfigPanel}">

                        <TextBlock Text="Configure Action"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>

                        <!-- vJoy Axis config -->
                        <StackPanel Spacing="6" IsVisible="{Binding ShowVJoyAxisConfig}">
                            <TextBlock Text="vJoy Device ID"/>
                            <NumericUpDown Value="{Binding EditVJoyDeviceId}"
                                          Minimum="1" Maximum="16"
                                          FormatString="0"
                                          Width="100" HorizontalAlignment="Left"/>
                            <TextBlock Text="Axis Index"/>
                            <NumericUpDown Value="{Binding EditVJoyAxisIndex}"
                                          Minimum="1" Maximum="8"
                                          FormatString="0"
                                          Width="100" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- vJoy Button config -->
                        <StackPanel Spacing="6" IsVisible="{Binding ShowVJoyButtonConfig}">
                            <TextBlock Text="vJoy Device ID"/>
                            <NumericUpDown Value="{Binding EditVJoyDeviceId}"
                                          Minimum="1" Maximum="16"
                                          FormatString="0"
                                          Width="100" HorizontalAlignment="Left"/>
                            <TextBlock Text="Button Index"/>
                            <NumericUpDown Value="{Binding EditVJoyButtonIndex}"
                                          Minimum="1" Maximum="128"
                                          FormatString="0"
                                          Width="100" HorizontalAlignment="Left"/>
                            <TextBlock Text="Press Threshold (0 – 1)"/>
                            <NumericUpDown Value="{Binding EditVJoyButtonThreshold}"
                                          Minimum="0" Maximum="1"
                                          Increment="0.05"
                                          FormatString="0.00"
                                          Width="100" HorizontalAlignment="Left"/>
                            <TextBlock Text="0.5 = half-travel (default) · 0.05 = hair-trigger · 0.9 = full-press"
                                       FontSize="10"
                                       Opacity="0.6"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                         <!-- vJoy Hat config -->
                         <StackPanel Spacing="6" IsVisible="{Binding ShowVJoyHatConfig}">
                             <TextBlock Text="vJoy Device ID"/>
                             <NumericUpDown Value="{Binding EditVJoyDeviceId}"
                                           Minimum="1" Maximum="16"
                                          FormatString="0"
                                          Width="100" HorizontalAlignment="Left"/>
                            <TextBlock Text="Hat Index"/>
                             <NumericUpDown Value="{Binding EditVJoyHatIndex}"
                                           Minimum="1" Maximum="4"
                                           FormatString="0"
                                           Width="100" HorizontalAlignment="Left"/>
                         </StackPanel>

                         <!-- Buttons to Hat config -->
                         <StackPanel Spacing="6" IsVisible="{Binding ShowButtonsToHatConfig}">
                             <TextBlock Text="Target vJoy Device ID"/>
                             <NumericUpDown Value="{Binding EditVJoyDeviceId}"
                                           Minimum="1" Maximum="16"
                                           FormatString="0"
                                           Width="100" HorizontalAlignment="Left"/>
                             <TextBlock Text="Target Hat Index"/>
                             <NumericUpDown Value="{Binding EditVJoyHatIndex}"
                                           Minimum="1" Maximum="4"
                                           FormatString="0"
                                           Width="100" HorizontalAlignment="Left"/>
                             <TextBlock Text="Directional source buttons"/>
                             <Grid ColumnDefinitions="Auto,Auto"
                                   RowDefinitions="Auto,Auto,Auto,Auto"
                                   ColumnSpacing="12"
                                   RowSpacing="6">
                                 <TextBlock Grid.Row="0" Grid.Column="0" Text="Up"/>
                                 <NumericUpDown Grid.Row="0" Grid.Column="1"
                                                Value="{Binding EditDirectionalUpButtonId}"
                                                Minimum="1" Maximum="128"
                                                FormatString="0"
                                                Width="100" HorizontalAlignment="Left"/>
                                 <TextBlock Grid.Row="1" Grid.Column="0" Text="Down"/>
                                 <NumericUpDown Grid.Row="1" Grid.Column="1"
                                                Value="{Binding EditDirectionalDownButtonId}"
                                                Minimum="1" Maximum="128"
                                                FormatString="0"
                                                Width="100" HorizontalAlignment="Left"/>
                                 <TextBlock Grid.Row="2" Grid.Column="0" Text="Left"/>
                                 <NumericUpDown Grid.Row="2" Grid.Column="1"
                                                Value="{Binding EditDirectionalLeftButtonId}"
                                                Minimum="1" Maximum="128"
                                                FormatString="0"
                                                Width="100" HorizontalAlignment="Left"/>
                                 <TextBlock Grid.Row="3" Grid.Column="0" Text="Right"/>
                                 <NumericUpDown Grid.Row="3" Grid.Column="1"
                                                Value="{Binding EditDirectionalRightButtonId}"
                                                Minimum="1" Maximum="128"
                                                FormatString="0"
                                                Width="100" HorizontalAlignment="Left"/>
                             </Grid>
                             <TextBlock TextWrapping="Wrap"
                                        FontSize="11"
                                        Opacity="0.65"
                                        Text="This mapping is mirrored onto each referenced source button in the current edit mode so all four buttons participate in the shared hat state."/>
                         </StackPanel>

                         <!-- Buttons to Axes config -->
                         <StackPanel Spacing="6" IsVisible="{Binding ShowButtonsToAxesConfig}">
                             <TextBlock Text="Target vJoy Device ID"/>
                             <NumericUpDown Value="{Binding EditVJoyDeviceId}"
                                           Minimum="1" Maximum="16"
                                           FormatString="0"
                                           Width="100" HorizontalAlignment="Left"/>
                             <TextBlock Text="Target X Axis Index"/>
                             <NumericUpDown Value="{Binding EditButtonsToAxesXAxisIndex}"
                                           Minimum="1" Maximum="8"
                                           FormatString="0"
                                           Width="100" HorizontalAlignment="Left"/>
                             <TextBlock Text="Target Y Axis Index"/>
                             <NumericUpDown Value="{Binding EditButtonsToAxesYAxisIndex}"
                                           Minimum="1" Maximum="8"
                                           FormatString="0"
                                           Width="100" HorizontalAlignment="Left"/>
                             <TextBlock Text="Directional source buttons"/>
                             <Grid ColumnDefinitions="Auto,Auto"
                                   RowDefinitions="Auto,Auto,Auto,Auto"
                                   ColumnSpacing="12"
                                   RowSpacing="6">
                                 <TextBlock Grid.Row="0" Grid.Column="0" Text="Up"/>
                                 <NumericUpDown Grid.Row="0" Grid.Column="1"
                                                Value="{Binding EditDirectionalUpButtonId}"
                                                Minimum="1" Maximum="128"
                                                FormatString="0"
                                                Width="100" HorizontalAlignment="Left"/>
                                 <TextBlock Grid.Row="1" Grid.Column="0" Text="Down"/>
                                 <NumericUpDown Grid.Row="1" Grid.Column="1"
                                                Value="{Binding EditDirectionalDownButtonId}"
                                                Minimum="1" Maximum="128"
                                                FormatString="0"
                                                Width="100" HorizontalAlignment="Left"/>
                                 <TextBlock Grid.Row="2" Grid.Column="0" Text="Left"/>
                                 <NumericUpDown Grid.Row="2" Grid.Column="1"
                                                Value="{Binding EditDirectionalLeftButtonId}"
                                                Minimum="1" Maximum="128"
                                                FormatString="0"
                                                Width="100" HorizontalAlignment="Left"/>
                                 <TextBlock Grid.Row="3" Grid.Column="0" Text="Right"/>
                                 <NumericUpDown Grid.Row="3" Grid.Column="1"
                                                Value="{Binding EditDirectionalRightButtonId}"
                                                Minimum="1" Maximum="128"
                                                FormatString="0"
                                                Width="100" HorizontalAlignment="Left"/>
                             </Grid>
                             <TextBlock TextWrapping="Wrap"
                                        FontSize="11"
                                        Opacity="0.65"
                                        Text="This mapping is mirrored onto each referenced source button in the current edit mode so the shared X/Y axis state updates from every configured button."/>
                         </StackPanel>

                         <!-- Macro config -->
                        <StackPanel Spacing="6" IsVisible="{Binding ShowMacroConfig}">
                            <TextBlock Text="Keys (comma-separated)"/>
                            <TextBox Text="{Binding EditMacroKeys}"
                                     PlaceholderText="e.g. LControl,C"
                                     Width="220"
                                     HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- Map to Keyboard config -->
                        <StackPanel Spacing="6" IsVisible="{Binding ShowMapToKeyboardConfig}">
                            <TextBlock Text="Keys (comma-separated, modifiers first)"/>
                            <TextBox Text="{Binding EditMapToKeyboardKeys}"
                                     PlaceholderText="e.g. LShift,A"
                                     Width="220"
                                     HorizontalAlignment="Left"/>
                            <TextBlock Text="Behavior"/>
                            <ComboBox ItemsSource="{Binding MapToKeyboardBehaviors}"
                                      SelectedItem="{Binding EditMapToKeyboardBehavior}"
                                      MinWidth="140"
                                      HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- Hat to Axes config -->
                        <StackPanel Spacing="6" IsVisible="{Binding ShowHatToAxisConfig}">
                            <TextBlock Text="Target vJoy Device ID"/>
                            <NumericUpDown Value="{Binding EditVJoyDeviceId}"
                                          Minimum="1" Maximum="16"
                                          FormatString="0"
                                          Width="100" HorizontalAlignment="Left"/>
                            <TextBlock Text="Target X Axis Index (0 = disabled)"/>
                            <NumericUpDown Value="{Binding EditHatToAxisXAxisIndex}"
                                          Minimum="0" Maximum="8"
                                          FormatString="0"
                                          Width="100" HorizontalAlignment="Left"/>
                            <TextBlock Text="Target Y Axis Index (0 = disabled)"/>
                            <NumericUpDown Value="{Binding EditHatToAxisYAxisIndex}"
                                          Minimum="0" Maximum="8"
                                          FormatString="0"
                                          Width="100" HorizontalAlignment="Left"/>
                            <TextBlock TextWrapping="Wrap"
                                       FontSize="11"
                                       Opacity="0.65"
                                       Text="Maps hat/POV direction to X/Y axis values. 0°=North(Y+), 90°=East(X+). Diagonals output ~0.707 on each axis. Set an index to 0 to disable that axis."/>
                        </StackPanel>

                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </DockPanel>

    </Grid>

</UserControl>
