<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JoystickGremlin.App.ViewModels"
             xmlns:actions="using:JoystickGremlin.Core.Actions"
             x:Class="JoystickGremlin.App.Views.BindingsPageView"
             x:DataType="vm:BindingsPageViewModel">

    <Grid ColumnDefinitions="200,180,*">

        <!-- ─── Device List ─── -->
        <DockPanel Grid.Column="0">
            <Border DockPanel.Dock="Top"
                    Padding="8,6"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <TextBlock Text="Devices" FontWeight="SemiBold" FontSize="13"/>
            </Border>

            <ListBox ItemsSource="{Binding Devices}"
                     SelectedItem="{Binding SelectedDevice}"
                     BorderThickness="0,0,1,0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:DeviceViewModel">
                        <TextBlock Text="{Binding Name}"
                                   TextWrapping="Wrap"
                                   Margin="4,4"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- ─── Input List ─── -->
        <DockPanel Grid.Column="1">
            <Border DockPanel.Dock="Top"
                    Padding="8,6"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <TextBlock Text="Inputs" FontWeight="SemiBold" FontSize="13"/>
            </Border>

            <ListBox ItemsSource="{Binding AvailableInputs}"
                     SelectedItem="{Binding SelectedInput}"
                     BorderThickness="0,0,1,0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:InputDescriptorViewModel">
                        <TextBlock Text="{Binding DisplayName}" Margin="4,4"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- ─── Bindings Editor ─── -->
        <DockPanel Grid.Column="2">

            <!-- Header: editing mode selector + live active-mode indicator -->
            <Border DockPanel.Dock="Top"
                    Padding="8,6"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Editing mode:"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding AvailableEditModeEntries}"
                                  SelectedItem="{Binding SelectedEditModeEntry}"
                                  MinWidth="160"
                                  IsEnabled="{Binding HasProfile}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ModeTreeEntry">
                                    <TextBlock Text="{Binding IndentedLabel}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Active:"
                                   FontSize="11"
                                   Opacity="0.55"/>
                        <TextBlock Text="{Binding CurrentModeName}"
                                   FontSize="11"
                                   Opacity="0.55"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Add-action toolbar -->
            <Border DockPanel.Dock="Top"
                    Padding="8,4"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <ComboBox ItemsSource="{Binding AvailableActionTypes}"
                              SelectedItem="{Binding SelectedNewActionType}"
                              MinWidth="140"
                              IsEnabled="{Binding HasProfile}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="actions:IActionDescriptor">
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="+ Add"
                            Command="{Binding AddActionCommand}"
                            FontSize="12"/>
                    <Button Content="− Remove"
                            Command="{Binding RemoveActionCommand}"
                            FontSize="12"/>
                    <Button Content="▲"
                            Command="{Binding MoveUpCommand}"
                            FontSize="12"
                            ToolTip.Tip="Move action up"/>
                    <Button Content="▼"
                            Command="{Binding MoveDownCommand}"
                            FontSize="12"
                            ToolTip.Tip="Move action down"/>
                </StackPanel>
            </Border>

            <!-- Bound action list + config form -->
            <Grid RowDefinitions="180,*">

                <!-- Action list -->
                <ListBox Grid.Row="0"
                         ItemsSource="{Binding BoundActions}"
                         SelectedItem="{Binding SelectedBoundAction}"
                         BorderThickness="0,0,0,1">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:BoundActionViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,3">
                                <TextBlock Text="{Binding ActionName}"
                                           FontWeight="SemiBold"
                                           MinWidth="120"/>
                                <TextBlock Text="{Binding ConfigSummary}"
                                           Opacity="0.6"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding InheritedFromMode, StringFormat='(↑ From: {0})'}"
                                           IsVisible="{Binding IsInherited}"
                                           Opacity="0.55"
                                           FontSize="10"
                                           FontStyle="Italic"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Config form / inherited-override panel -->
                <ScrollViewer Grid.Row="1">
                    <StackPanel Margin="12" Spacing="10">

                        <!-- Inherited action info + override button -->
                        <StackPanel Spacing="6" IsVisible="{Binding ShowInheritedPanel}">
                            <TextBlock Text="Inherited Action"
                                       FontWeight="SemiBold"
                                       FontSize="14"/>
                            <TextBlock TextWrapping="Wrap"
                                       Opacity="0.7"
                                       FontSize="12"
                                       Text="This action is inherited from a parent mode. It is read-only here. Click Override to create a local copy in the editing mode."/>
                            <Button Content="Override in this mode"
                                    Command="{Binding OverrideInheritedActionCommand}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- Configure Action form (own actions only) -->
                        <StackPanel Spacing="10" IsVisible="{Binding ShowConfigPanel}">

                        <TextBlock Text="Configure Action"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>

                        <!-- vJoy Axis config -->
                        <StackPanel Spacing="6" IsVisible="{Binding ShowVJoyAxisConfig}">
                            <TextBlock Text="vJoy Device ID"/>
                            <NumericUpDown Value="{Binding EditVJoyDeviceId}"
                                          Minimum="1" Maximum="16"
                                          FormatString="0"
                                          Width="100" HorizontalAlignment="Left"/>
                            <TextBlock Text="Axis Index"/>
                            <NumericUpDown Value="{Binding EditVJoyAxisIndex}"
                                          Minimum="1" Maximum="8"
                                          FormatString="0"
                                          Width="100" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- vJoy Button config -->
                        <StackPanel Spacing="6" IsVisible="{Binding ShowVJoyButtonConfig}">
                            <TextBlock Text="vJoy Device ID"/>
                            <NumericUpDown Value="{Binding EditVJoyDeviceId}"
                                          Minimum="1" Maximum="16"
                                          FormatString="0"
                                          Width="100" HorizontalAlignment="Left"/>
                            <TextBlock Text="Button Index"/>
                            <NumericUpDown Value="{Binding EditVJoyButtonIndex}"
                                          Minimum="1" Maximum="128"
                                          FormatString="0"
                                          Width="100" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- vJoy Hat config -->
                        <StackPanel Spacing="6" IsVisible="{Binding ShowVJoyHatConfig}">
                            <TextBlock Text="vJoy Device ID"/>
                            <NumericUpDown Value="{Binding EditVJoyDeviceId}"
                                          Minimum="1" Maximum="16"
                                          FormatString="0"
                                          Width="100" HorizontalAlignment="Left"/>
                            <TextBlock Text="Hat Index"/>
                            <NumericUpDown Value="{Binding EditVJoyHatIndex}"
                                          Minimum="1" Maximum="4"
                                          FormatString="0"
                                          Width="100" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- Change Mode config -->
                        <StackPanel Spacing="6" IsVisible="{Binding ShowChangeModeConfig}">
                            <TextBlock Text="Target Mode"/>
                            <ComboBox ItemsSource="{Binding AvailableModeNames}"
                                      SelectedItem="{Binding EditTargetModeName}"
                                      MinWidth="160"
                                      HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- Macro config -->
                        <StackPanel Spacing="6" IsVisible="{Binding ShowMacroConfig}">
                            <TextBlock Text="Keys (comma-separated)"/>
                            <TextBox Text="{Binding EditMacroKeys}"
                                     PlaceholderText="e.g. LControl,C"
                                     Width="220"
                                     HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- Map to Keyboard config -->
                        <StackPanel Spacing="6" IsVisible="{Binding ShowMapToKeyboardConfig}">
                            <TextBlock Text="Keys (comma-separated, modifiers first)"/>
                            <TextBox Text="{Binding EditMapToKeyboardKeys}"
                                     PlaceholderText="e.g. LShift,A"
                                     Width="220"
                                     HorizontalAlignment="Left"/>
                            <TextBlock Text="Behavior"/>
                            <ComboBox ItemsSource="{Binding MapToKeyboardBehaviors}"
                                      SelectedItem="{Binding EditMapToKeyboardBehavior}"
                                      MinWidth="140"
                                      HorizontalAlignment="Left"/>
                        </StackPanel>

                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </DockPanel>

    </Grid>

</UserControl>
