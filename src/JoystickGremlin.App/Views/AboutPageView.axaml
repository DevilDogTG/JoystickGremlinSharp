<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JoystickGremlin.App.ViewModels"
             x:Class="JoystickGremlin.App.Views.AboutPageView"
             x:DataType="vm:AboutPageViewModel">

    <ScrollViewer>
        <StackPanel Margin="16" MaxWidth="480" Spacing="20">

            <TextBlock Text="About" FontWeight="SemiBold" FontSize="18"/>

            <!-- App identity -->
            <StackPanel Spacing="6">
                <TextBlock Text="{Binding AppName}"
                           FontSize="22"
                           FontWeight="Bold"/>
                <TextBlock Text="{Binding VersionLabel}"
                           FontSize="14"
                           Opacity="0.7"/>
                <TextBlock Text="{Binding Copyright}"
                           FontSize="12"
                           Opacity="0.6"/>
            </StackPanel>

            <!-- Updates -->
            <Border Padding="0,8,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Updates" FontWeight="SemiBold" FontSize="15"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Check for Updates"
                                Command="{Binding CheckForUpdatesCommand}"
                                FontSize="12"
                                Cursor="Hand"
                                ToolTip.Tip="Check GitHub Releases for a newer version"/>
                        <Button Content="⬇ Download Update"
                                Command="{Binding DownloadUpdateCommand}"
                                IsVisible="{Binding IsUpdateAvailable}"
                                FontSize="12"
                                Cursor="Hand"
                                ToolTip.Tip="Open the latest installer download in your browser"/>
                    </StackPanel>
                    <TextBlock Text="{Binding UpdateStatusMessage}"
                               IsVisible="{Binding UpdateStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Opacity="0.8"/>
                </StackPanel>
            </Border>

            <!-- Repository link -->
            <Border Padding="0,8,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Source Code" FontWeight="SemiBold" FontSize="15"/>
                    <SelectableTextBlock Text="{Binding RepositoryUrl}"
                                         Foreground="{DynamicResource SystemAccentColor}"
                                         FontSize="13"
                                         ToolTip.Tip="Select all (Ctrl+A) and copy (Ctrl+C) to copy the URL"/>
                    <Button Content="Open in Browser"
                            Command="{Binding OpenRepositoryCommand}"
                            FontSize="12"
                            Cursor="Hand"
                            ToolTip.Tip="{Binding RepositoryUrl}"/>
                </StackPanel>
            </Border>

            <!-- License -->
            <Border Padding="0,8,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="License" FontWeight="SemiBold" FontSize="15"/>
                    <TextBlock Text="{Binding License}"
                               FontSize="13"
                               Opacity="0.85"/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="11">
                        This software is free and open source. See the LICENSE file in the repository for full license text.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Attribution -->
            <Border Padding="0,8,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Based On" FontWeight="SemiBold" FontSize="15"/>
                    <TextBlock Text="{Binding Attribution}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Opacity="0.75"/>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Original project:" FontSize="12" Opacity="0.6"/>
                        <SelectableTextBlock Text="{Binding OriginalRepoUrl}"
                                             Foreground="{DynamicResource SystemAccentColor}"
                                             FontSize="12"
                                             ToolTip.Tip="Select all (Ctrl+A) and copy (Ctrl+C) to copy the URL"/>
                        <Button Content="Open Original Repository"
                                Command="{Binding OpenOriginalRepoCommand}"
                                FontSize="12"
                                Cursor="Hand"
                                ToolTip.Tip="{Binding OriginalRepoUrl}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
