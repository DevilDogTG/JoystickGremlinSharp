<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JoystickGremlin.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="680"
        x:Class="JoystickGremlin.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/icon.ico"
        Title="Joystick Gremlin"
        Width="1024" Height="680"
        MinWidth="800" MinHeight="500">

    <DockPanel>

        <!-- ─── Top Toolbar ─── -->
        <Border DockPanel.Dock="Top"
                Padding="8,6"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto"
                  ColumnSpacing="8">

                <!-- Profile controls -->
                <Button Grid.Column="0"
                        Content="📂  Open"
                        Command="{Binding OpenProfileCommand}"
                        ToolTip.Tip="Open a profile file"/>
                <Button Grid.Column="1"
                        Content="New"
                        Command="{Binding NewProfileCommand}"
                        ToolTip.Tip="Create a new empty profile"/>
                <Button Grid.Column="2"
                        Content="💾  Save"
                        Command="{Binding SaveProfileCommand}"
                        ToolTip.Tip="Save profile to current file (or prompt if unsaved)"/>
                <Button Grid.Column="3"
                        Content="Save As…"
                        Command="{Binding SaveAsProfileCommand}"
                        ToolTip.Tip="Save profile to a new file"/>

                <!-- Profile path display -->
                <TextBlock Grid.Column="4"
                           Text="{Binding ProfilePath}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Opacity="0.6"
                           FontSize="12"/>

                <!-- Active mode -->
                <StackPanel Grid.Column="5"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <TextBlock Text="Mode:"
                               VerticalAlignment="Center"
                               Opacity="0.6"
                               FontSize="12"/>
                    <ComboBox ItemsSource="{Binding AvailableModeEntries}"
                              SelectedItem="{Binding SelectedModeEntry}"
                              IsEnabled="{Binding HasProfile}"
                              MinWidth="120"
                              FontSize="12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ModeTreeEntry">
                                <TextBlock Text="{Binding IndentedLabel}" FontFamily="Consolas,Courier New"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Start / Stop toggle -->
                <Button Grid.Column="6"
                        Content="{Binding ToggleButtonLabel}"
                        Command="{Binding ToggleActiveCommand}"
                        MinWidth="90"
                        ToolTip.Tip="Start or stop the Gremlin event pipeline"/>

            </Grid>
        </Border>

        <!-- ─── Left Navigation Sidebar ─── -->
        <ListBox DockPanel.Dock="Left"
                 Width="52"
                 ItemsSource="{Binding NavItems}"
                 SelectedItem="{Binding SelectedNavItem}"
                 BorderThickness="0,0,1,0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:NavItemViewModel">
                    <StackPanel Margin="3,3" HorizontalAlignment="Center"
                                ToolTip.Tip="{Binding Title}">
                        <TextBlock Text="{Binding Icon}"
                                   FontSize="18"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- ─── Page Content Area ─── -->
        <ContentControl Content="{Binding CurrentPage}"/>

    </DockPanel>

</Window>

