<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JoystickGremlin.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="680"
        x:Class="JoystickGremlin.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/icon.ico"
        Title="Joystick Gremlin"
        Width="1024" Height="680"
        MinWidth="900" MinHeight="500">

    <DockPanel>

        <!-- ─── Top Toolbar ─── -->
        <Border DockPanel.Dock="Top"
                Padding="8,6"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">

                <!-- Profile label -->
                <TextBlock Grid.Column="0"
                           Text="Profile:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <!-- Profile quick-switch dropdown -->
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailableProfileEntries}"
                          SelectedItem="{Binding SelectedProfileEntry}"
                          PlaceholderText="(no profiles — use Profile page to create one)"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Stretch"
                          ToolTip.Tip="Select active profile">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayLabel}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Start / Stop toggle -->
                <Button Grid.Column="2"
                        Content="{Binding ToggleButtonLabel}"
                        Command="{Binding ToggleActiveCommand}"
                        MinWidth="90"
                        ToolTip.Tip="Start or stop the Gremlin event pipeline"/>

            </Grid>
        </Border>

        <!-- ─── Left Navigation Sidebar ─── -->
        <ListBox DockPanel.Dock="Left"
                 Width="52"
                 ItemsSource="{Binding NavItems}"
                 SelectedItem="{Binding SelectedNavItem}"
                 BorderThickness="0,0,1,0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:NavItemViewModel">
                    <StackPanel Margin="3,3" HorizontalAlignment="Center"
                                ToolTip.Tip="{Binding Title}">
                        <TextBlock Text="{Binding Icon}"
                                   FontSize="18"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- ─── Page Content Area ─── -->
        <ContentControl Content="{Binding CurrentPage}"/>

    </DockPanel>

</Window>

