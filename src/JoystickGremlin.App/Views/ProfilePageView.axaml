<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JoystickGremlin.App.ViewModels"
             xmlns:profile="using:JoystickGremlin.Core.Profile"
             x:Class="JoystickGremlin.App.Views.ProfilePageView"
             x:DataType="vm:ProfilePageViewModel">

    <Grid ColumnDefinitions="280,4,*">

        <!-- ─── Profile Library List ─── -->
        <DockPanel Grid.Column="0">

            <!-- Toolbar -->
            <Border DockPanel.Dock="Top"
                    Padding="4,4"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button Content="− Delete"
                            Command="{Binding DeleteProfileCommand}"
                            FontSize="12"/>
                    <Button Content="🔄 Refresh"
                            Command="{Binding RefreshCommand}"
                            FontSize="12"
                            ToolTip.Tip="Rescan the profiles folder"/>
                </StackPanel>
            </Border>

            <TreeView ItemsSource="{Binding ProfileTree}"
                      SelectedItem="{Binding SelectedNode}"
                      BorderThickness="0,0,1,0">
                <TreeView.Styles>
                    <Style Selector="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True"/>
                    </Style>
                </TreeView.Styles>
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                        <TextBlock Margin="2,1"
                                   Text="{Binding Label}"
                                   FontWeight="{Binding Entry, Converter={x:Static ObjectConverters.IsNull}, ConverterParameter=SemiBold}"/>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

        </DockPanel>

        <GridSplitter Grid.Column="1"
                      Width="4"
                      Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                      ResizeDirection="Columns"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"/>

        <!-- ─── Create New Profile ─── -->
        <ScrollViewer Grid.Column="2">
            <StackPanel Margin="16" Spacing="16">

                <TextBlock Text="Profile Library" FontWeight="SemiBold" FontSize="16"/>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Profiles Folder" FontSize="12" Opacity="0.7"/>
                        <TextBlock Text="{Binding ProfilesFolderPath}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Opacity="0.6"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Open Folder"
                            Command="{Binding OpenProfileFolderCommand}"
                            FontSize="11"
                            Padding="10,4"
                            VerticalAlignment="Center"/>
                </Grid>

                <Border Padding="0,8,0,0"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding EditorTitle}" FontWeight="SemiBold" FontSize="14"/>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Name"/>
                            <TextBox Text="{Binding NewProfileName}"
                                      PlaceholderText="My Profile"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Category (subfolder, optional)"/>
                            <TextBox Text="{Binding SelectedCategory}"
                                     PlaceholderText="(none)"
                                     IsEnabled="{Binding IsEditMode, Converter={x:Static BoolConverters.Not}}"/>
                        </StackPanel>

                        <Button Content="{Binding SubmitButtonLabel}"
                                Command="{Binding SubmitProfileCommand}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>
