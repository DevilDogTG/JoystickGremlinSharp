<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JoystickGremlin.App.ViewModels"
             x:Class="JoystickGremlin.App.Views.ProfilePageView"
             x:DataType="vm:ProfilePageViewModel">

    <Grid ColumnDefinitions="260,*">

        <!-- ─── Mode List Panel ─── -->
        <DockPanel Grid.Column="0">

            <!-- Add / Remove toolbar -->
            <Border DockPanel.Dock="Top"
                    Padding="4,4"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button Content="+ Add"
                            Command="{Binding AddModeCommand}"
                            FontSize="12"/>
                    <Button Content="− Remove"
                            Command="{Binding RemoveModeCommand}"
                            FontSize="12"/>
                </StackPanel>
            </Border>

            <ListBox ItemsSource="{Binding Modes}"
                     SelectedItem="{Binding SelectedMode}"
                     BorderThickness="0,0,1,0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ModeViewModel">
                        <StackPanel Margin="4,4" Spacing="2">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                            <TextBlock FontSize="11" Opacity="0.6"
                                       Text="{Binding ParentModeName,
                                                      FallbackValue='(root mode)',
                                                      TargetNullValue='(root mode)'}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </DockPanel>

        <!-- ─── Edit Form ─── -->
        <ScrollViewer Grid.Column="1">
            <StackPanel Margin="16"
                        Spacing="16"
                        IsEnabled="{Binding SelectedMode, Converter={x:Static ObjectConverters.IsNotNull}}">

                <TextBlock Text="Edit Mode" FontWeight="SemiBold" FontSize="16"/>

                <StackPanel Spacing="4">
                    <TextBlock Text="Name"/>
                    <TextBox Text="{Binding EditName}" PlaceholderText="Mode name"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Parent Mode"/>
                    <ComboBox ItemsSource="{Binding AvailableParentNames}"
                              SelectedItem="{Binding EditParentName}"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>

                <Button Content="Apply Changes"
                        Command="{Binding CommitEditCommand}"
                        HorizontalAlignment="Left"/>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>

