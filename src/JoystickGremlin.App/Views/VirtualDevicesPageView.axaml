<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JoystickGremlin.App.ViewModels"
             xmlns:live="using:JoystickGremlin.App.ViewModels.InputViewer"
             x:Class="JoystickGremlin.App.Views.VirtualDevicesPageView"
             x:DataType="vm:VirtualDevicesPageViewModel">

    <UserControl.Styles>
        <Style Selector="Border.btn-pressed">
            <Setter Property="Background" Value="#22C55E"/>
        </Style>
        <Style Selector="Border.btn-released">
            <Setter Property="Background" Value="#6B7280"/>
        </Style>
        <Style Selector="Border.hat-active">
            <Setter Property="Background" Value="#3B82F6"/>
        </Style>
        <Style Selector="Border.hat-center-active">
            <Setter Property="Background" Value="#64748B"/>
        </Style>
        <Style Selector="Border.hat-inactive">
            <Setter Property="Background" Value="#374151"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="260,*">
        <DockPanel Grid.Column="0">
            <Border DockPanel.Dock="Top"
                    Padding="8,6"
                    BorderThickness="0,0,1,1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Virtual Devices"
                               FontWeight="SemiBold"
                               FontSize="13"/>
                    <Button Grid.Column="1"
                            Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            FontSize="12"/>
                </Grid>
            </Border>

            <ListBox ItemsSource="{Binding Devices}"
                     SelectedItem="{Binding SelectedDevice}"
                     BorderThickness="0,0,1,0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:VirtualDeviceViewModel">
                        <StackPanel Margin="6,4" Spacing="2">
                            <TextBlock Text="{Binding Title}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding StatusText}"
                                       FontSize="11"
                                       Opacity="0.7"/>
                            <TextBlock Text="{Binding AxisCount, StringFormat='Axes: {0}'}"
                                       FontSize="10"
                                       Opacity="0.55"/>
                            <TextBlock Text="{Binding ButtonCount, StringFormat='Buttons: {0}'}"
                                       FontSize="10"
                                       Opacity="0.55"/>
                            <TextBlock Text="{Binding HatCount, StringFormat='Hats: {0}'}"
                                       FontSize="10"
                                       Opacity="0.55"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <DockPanel Grid.Column="1">
            <Border DockPanel.Dock="Top"
                    Padding="12,8"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Spacing="3">
                    <TextBlock Text="{Binding SelectedDevice.Title, FallbackValue='Virtual Devices'}"
                               FontWeight="SemiBold"
                               FontSize="14"/>
                    <TextBlock Text="{Binding SelectedDevice.StatusText, FallbackValue='Select a vJoy device'}"
                               FontSize="12"
                               Opacity="0.75"/>
                    <TextBlock Text="Axis/button/hat counts are configured in the vJoy Control Panel. This page shows status and live output tracked by this app."
                               FontSize="11"
                               Opacity="0.55"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border DockPanel.Dock="Top"
                    Padding="12,8"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Acquire"
                            Command="{Binding SelectedDevice.AcquireCommand}"
                            IsEnabled="{Binding SelectedDevice.CanAcquire, FallbackValue=False}"/>
                    <Button Content="Release"
                            Command="{Binding SelectedDevice.ReleaseCommand}"
                            IsEnabled="{Binding SelectedDevice.CanRelease, FallbackValue=False}"/>
                    <Button Content="Reset"
                            Command="{Binding SelectedDevice.ResetCommand}"
                            IsEnabled="{Binding SelectedDevice.CanReset, FallbackValue=False}"/>
                    <Button Content="Open vJoy Control Panel"
                            Command="{Binding OpenVJoyControlPanelCommand}"
                            IsEnabled="{Binding HasConfigurationTool}"/>
                </StackPanel>
            </Border>

            <ScrollViewer>
                <StackPanel Margin="12" Spacing="18">
                    <TextBlock Text="Select a vJoy device on the left."
                               Opacity="0.5"
                               IsVisible="{Binding SelectedDevice,
                                   Converter={x:Static ObjectConverters.IsNull}}"/>

                    <Grid ColumnDefinitions="Auto,Auto"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="12"
                          RowSpacing="2">
                        <TextBlock Text="Axes:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectedDevice.AxisCount, FallbackValue=0}"/>
                        <TextBlock Grid.Row="1" Text="Buttons:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding SelectedDevice.ButtonCount, FallbackValue=0}"/>
                        <TextBlock Grid.Row="2" Text="Hats:" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding SelectedDevice.HatCount, FallbackValue=0}"/>
                    </Grid>

                    <StackPanel Spacing="6"
                                IsVisible="{Binding SelectedDevice.HasAxes, FallbackValue=False}">
                        <TextBlock Text="Axes"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                        <ItemsControl ItemsSource="{Binding SelectedDevice.Axes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="live:AxisLiveViewModel">
                                    <Grid ColumnDefinitions="60,*,55" Margin="0,3">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Label}"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"/>
                                        <ProgressBar Grid.Column="1"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding DisplayPercent}"
                                                     Height="16"
                                                     VerticalAlignment="Center"
                                                     Margin="4,0"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ValueLabel}"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   HorizontalAlignment="Right"
                                                   FontFamily="Consolas,Monospace"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Spacing="6"
                                IsVisible="{Binding SelectedDevice.HasButtons, FallbackValue=False}">
                        <TextBlock Text="Buttons"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                        <ItemsControl ItemsSource="{Binding SelectedDevice.Buttons}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="live:ButtonLiveViewModel">
                                    <Border Width="38"
                                            Height="38"
                                            Margin="3"
                                            CornerRadius="19"
                                            Classes.btn-pressed="{Binding IsPressed}"
                                            Classes.btn-released="{Binding !IsPressed}"
                                            ToolTip.Tip="{Binding Label}">
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Spacing="6"
                                IsVisible="{Binding SelectedDevice.HasHats, FallbackValue=False}">
                        <TextBlock Text="Hats"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                        <ItemsControl ItemsSource="{Binding SelectedDevice.Hats}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="live:HatLiveViewModel">
                                    <StackPanel Margin="8,0" Spacing="4">
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="11"
                                                   HorizontalAlignment="Center"/>
                                        <Grid RowDefinitions="28,28,28" ColumnDefinitions="28,28,28">
                                            <Border Grid.Row="0" Grid.Column="0" CornerRadius="4" Margin="1"
                                                    Classes.hat-active="{Binding IsNorthWest}"
                                                    Classes.hat-inactive="{Binding !IsNorthWest}"/>
                                            <Border Grid.Row="0" Grid.Column="1" CornerRadius="4" Margin="1"
                                                    Classes.hat-active="{Binding IsNorth}"
                                                    Classes.hat-inactive="{Binding !IsNorth}"/>
                                            <Border Grid.Row="0" Grid.Column="2" CornerRadius="4" Margin="1"
                                                    Classes.hat-active="{Binding IsNorthEast}"
                                                    Classes.hat-inactive="{Binding !IsNorthEast}"/>
                                            <Border Grid.Row="1" Grid.Column="0" CornerRadius="4" Margin="1"
                                                    Classes.hat-active="{Binding IsWest}"
                                                    Classes.hat-inactive="{Binding !IsWest}"/>
                                            <Border Grid.Row="1" Grid.Column="1" CornerRadius="4" Margin="1"
                                                    Classes.hat-center-active="{Binding IsCenter}"
                                                    Classes.hat-inactive="{Binding !IsCenter}">
                                                <TextBlock Text="●"
                                                           FontSize="10"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="White"/>
                                            </Border>
                                            <Border Grid.Row="1" Grid.Column="2" CornerRadius="4" Margin="1"
                                                    Classes.hat-active="{Binding IsEast}"
                                                    Classes.hat-inactive="{Binding !IsEast}"/>
                                            <Border Grid.Row="2" Grid.Column="0" CornerRadius="4" Margin="1"
                                                    Classes.hat-active="{Binding IsSouthWest}"
                                                    Classes.hat-inactive="{Binding !IsSouthWest}"/>
                                            <Border Grid.Row="2" Grid.Column="1" CornerRadius="4" Margin="1"
                                                    Classes.hat-active="{Binding IsSouth}"
                                                    Classes.hat-inactive="{Binding !IsSouth}"/>
                                            <Border Grid.Row="2" Grid.Column="2" CornerRadius="4" Margin="1"
                                                    Classes.hat-active="{Binding IsSouthEast}"
                                                    Classes.hat-inactive="{Binding !IsSouthEast}"/>
                                        </Grid>
                                        <TextBlock Text="{Binding DirectionLabel}"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   Opacity="0.7"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
