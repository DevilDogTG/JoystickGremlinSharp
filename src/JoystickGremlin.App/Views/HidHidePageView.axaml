<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JoystickGremlin.App.ViewModels"
             x:Class="JoystickGremlin.App.Views.HidHidePageView"
             x:DataType="vm:HidHidePageViewModel">

    <ScrollViewer>
        <StackPanel Margin="16" MaxWidth="620" Spacing="16">

            <TextBlock Text="HidHide Integration" FontWeight="SemiBold" FontSize="18"/>

            <!-- ─── Status banner ─── -->
            <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    CornerRadius="4"
                    Padding="12,8">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusText}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               FontStyle="Italic"
                               Opacity="0.8"/>
                    <Button Grid.Column="1"
                            Content="🔄 Refresh"
                            Command="{Binding RefreshCommand}"
                            Padding="8,4"
                            FontSize="11"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <!-- ─── Driver not installed notice ─── -->
            <Border Background="{StaticResource WarningBackgroundBrush}"
                    CornerRadius="4"
                    Padding="10,8"
                    IsVisible="{Binding !IsDriverInstalled}">
                <StackPanel Spacing="6">
                    <TextBlock Text="⚠️ HidHide driver is not installed. Device hiding is unavailable."
                               Foreground="{StaticResource WarningForegroundBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="Install HidHide and restart the application to use this feature."
                               Foreground="{StaticResource WarningForegroundBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"/>
                    <Button Content="⬇  Download HidHide"
                            Tag="{Binding DownloadUrl}"
                            Click="DownloadButton_Click"
                            FontSize="11"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- ─── Master toggles ─── -->
            <Border Padding="0,8,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="General" FontWeight="SemiBold" FontSize="15"/>
                    <CheckBox Content="Enable HidHide integration"
                              IsChecked="{Binding EnableHidHide}"
                              ToolTip.Tip="Master switch. When disabled, no devices are ever hidden regardless of other settings."/>
                    <CheckBox Content="Hide devices automatically when pipeline starts"
                              IsChecked="{Binding AutoHideOnPipelineRun}"
                              IsEnabled="{Binding EnableHidHide}"
                              ToolTip.Tip="Automatically hides the configured devices when the Gremlin event pipeline starts, and unhides them when it stops."/>

                    <!-- Manual override buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8" IsEnabled="{Binding EnableHidHide}">
                        <Button Content="▶  Apply Hiding Now"
                                Command="{Binding ApplyNowCommand}"
                                ToolTip.Tip="Immediately hide all configured devices."/>
                        <Button Content="⏹  Revert Hiding Now"
                                Command="{Binding RevertNowCommand}"
                                ToolTip.Tip="Immediately unhide all configured devices."/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ─── Device picker ─── -->
            <Border Padding="0,8,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Devices to Hide" FontWeight="SemiBold" FontSize="15"/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="11">
                        Select which physical input devices should be hidden from other applications while the pipeline runs.
                        Only devices visible to this application (via DILL) with a resolved Windows Device Instance ID are shown.
                    </TextBlock>

                    <!-- Header -->
                    <Grid ColumnDefinitions="40,*,220"
                          IsVisible="{Binding DeviceRows.Count}">
                        <TextBlock Grid.Column="0" Text="Hide" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Device Name" FontSize="11" FontWeight="SemiBold" Margin="4,0"/>
                        <TextBlock Grid.Column="2" Text="Instance ID" FontSize="11" FontWeight="SemiBold" Margin="4,0"/>
                    </Grid>

                    <!-- Connected devices -->
                    <ItemsControl ItemsSource="{Binding DeviceRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:HidHideDeviceRowViewModel">
                                <Grid ColumnDefinitions="40,*,220" Margin="0,2">
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsHidden}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding FriendlyName}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="4,0"
                                               ToolTip.Tip="{Binding FriendlyName}"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding InstanceId}"
                                               VerticalAlignment="Center"
                                               FontSize="10"
                                               Opacity="0.6"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="4,0"
                                               ToolTip.Tip="{Binding InstanceId}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state -->
                    <TextBlock Text="No physical devices detected with resolved Instance IDs. Connect your devices and refresh."
                               FontSize="11"
                               Opacity="0.5"
                               TextWrapping="Wrap"
                               IsVisible="{Binding !DeviceRows.Count}"/>
                </StackPanel>
            </Border>

            <!-- ─── Stale / offline entries ─── -->
            <Border Padding="0,8,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    IsVisible="{Binding StaleDeviceRows.Count}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Remembered Devices (Not Connected)" FontWeight="SemiBold" FontSize="15"/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="11">
                        These devices were configured to be hidden but are not currently connected.
                        They will be hidden when reconnected. Remove entries you no longer need.
                    </TextBlock>

                    <ItemsControl ItemsSource="{Binding StaleDeviceRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:HidHideDeviceRowViewModel">
                                <Grid ColumnDefinitions="*,220,60" Margin="0,2">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding FriendlyName}"
                                               VerticalAlignment="Center"
                                               Opacity="0.5"
                                               FontStyle="Italic"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,4,0"
                                               ToolTip.Tip="{Binding FriendlyName}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding InstanceId}"
                                               VerticalAlignment="Center"
                                               FontSize="10"
                                               Opacity="0.4"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="4,0"
                                               ToolTip.Tip="{Binding InstanceId}"/>
                                    <Button Grid.Column="2"
                                            Content="🗑 Remove"
                                            Click="RemoveStale_Click"
                                            Tag="{Binding}"
                                            FontSize="11"
                                            Padding="4,2"
                                            HorizontalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ─── Application whitelist (read-only) ─── -->
            <Border Padding="0,8,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Application Whitelist" FontWeight="SemiBold" FontSize="15"/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="11">
                        This application is automatically added to the HidHide bypass list when hiding is applied,
                        so Joystick Gremlin can continue to receive input from hidden devices.
                    </TextBlock>
                    <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            CornerRadius="4"
                            Padding="10,6">
                        <TextBlock Text="{Binding OwnExePath}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Opacity="0.8"/>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
