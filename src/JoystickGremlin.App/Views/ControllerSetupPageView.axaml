<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JoystickGremlin.App.ViewModels"
             xmlns:actions="using:JoystickGremlin.Core.Actions"
             xmlns:inputviewer="using:JoystickGremlin.App.ViewModels.InputViewer"
             x:Class="JoystickGremlin.App.Views.ControllerSetupPageView"
             x:DataType="vm:ControllerSetupPageViewModel">

    <UserControl.Styles>
        <Style Selector="Border.btn-pressed">
            <Setter Property="Background" Value="#22C55E"/>
        </Style>
        <Style Selector="Border.btn-released">
            <Setter Property="Background" Value="#6B7280"/>
        </Style>
        <Style Selector="Border.hat-active">
            <Setter Property="Background" Value="#3B82F6"/>
        </Style>
        <Style Selector="Border.hat-center-active">
            <Setter Property="Background" Value="#64748B"/>
        </Style>
        <Style Selector="Border.hat-inactive">
            <Setter Property="Background" Value="#374151"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="220,6,320,6,*">

        <DockPanel Grid.Column="0"
                   MinWidth="170">
            <Border DockPanel.Dock="Top"
                    Padding="6,5"
                    BorderThickness="0,0,1,1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <TextBlock Text="Devices"
                           FontWeight="SemiBold"
                           FontSize="13"/>
            </Border>

            <ListBox ItemsSource="{Binding Devices}"
                     SelectedItem="{Binding SelectedDevice}"
                     BorderThickness="0,0,1,0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:DeviceViewModel">
                        <StackPanel Margin="4,3" Spacing="2">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding InputSummary}"
                                       FontSize="11"
                                       Opacity="0.65"/>
                            <TextBlock Text="{Binding LastInputLabel}"
                                       FontSize="10"
                                       Opacity="0.55"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <GridSplitter Grid.Column="1"
                      Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True"/>

        <DockPanel Grid.Column="2"
                   MinWidth="260">
            <Border DockPanel.Dock="Top"
                    Padding="6,5"
                    BorderThickness="0,0,1,1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                <StackPanel Spacing="2">
                    <TextBlock Text="Inputs"
                               FontWeight="SemiBold"
                               FontSize="13"/>
                    <TextBlock Text="{Binding SelectedDevice.InputSummary, FallbackValue='Select a device'}"
                               FontSize="11"
                               Opacity="0.6"/>
                </StackPanel>
            </Border>

            <ListBox ItemsSource="{Binding InputRows}"
                     SelectedItem="{Binding SelectedInputRow}"
                     BorderThickness="0,0,1,0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:UnifiedInputRowViewModel">
                        <Grid ColumnDefinitions="14,72,112,*"
                              ColumnSpacing="6"
                              Margin="2,2">
                            <TextBlock Grid.Column="0"
                                        Text="●"
                                        VerticalAlignment="Center"
                                       Foreground="LimeGreen"
                                       IsVisible="{Binding IsActive}"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding Label}"
                                       VerticalAlignment="Center"/>

                            <Grid Grid.Column="2">
                                <!-- Full-width axis meter with centered fill and overlaid value -->
                                <Grid Height="10"
                                      VerticalAlignment="Center"
                                      ClipToBounds="True"
                                      IsVisible="{Binding IsAxis}">
                                    <Border Background="#252525" CornerRadius="2"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="{Binding Axis.BarLeftWidth}"/>
                                            <ColumnDefinition Width="{Binding Axis.BarFillWidth}"/>
                                            <ColumnDefinition Width="{Binding Axis.BarRightWidth}"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="1" Background="#3B82F6" CornerRadius="1"/>
                                    </Grid>
                                    <Rectangle Width="1" HorizontalAlignment="Center" Fill="#555555"/>
                                    <TextBlock Text="{Binding Axis.ValueLabel, FallbackValue='0.00'}"
                                               FontSize="8"
                                               FontFamily="Consolas,Monospace"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="White"/>
                                </Grid>

                                <TextBlock Text="{Binding Button.IsPressed, StringFormat='{}{0:Pressed;Pressed;Released}'}"
                                            FontSize="10"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsButton}"/>

                                <TextBlock Text="{Binding Hat.DirectionLabel, FallbackValue='Center'}"
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding IsHat}"/>
                            </Grid>

                            <TextBlock Grid.Column="3"
                                       Text="{Binding BoundActions}"
                                       Opacity="0.7"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <GridSplitter Grid.Column="3"
                      Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True"/>

        <Grid Grid.Column="4"
              RowDefinitions="*,6,*"
              MinWidth="320">

            <!-- ─── Row 0: All-inputs live state for selected device ─── -->
            <DockPanel Grid.Row="0">
                <Border DockPanel.Dock="Top"
                        Padding="12,8"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                    <TextBlock Text="{Binding SelectedDevice.Name, FallbackValue='Controller Setup'}"
                               FontWeight="SemiBold"
                               FontSize="14"/>
                </Border>

                <TextBlock Margin="12"
                           Opacity="0.5"
                           IsVisible="{Binding !HasSelectedDevice}"
                           Text="Select a device to see live input state."/>

                <ScrollViewer IsVisible="{Binding HasSelectedDevice}">
                    <StackPanel Margin="12" Spacing="12">

                        <!-- Axes -->
                        <StackPanel Spacing="6"
                                    IsVisible="{Binding SelectedDeviceLiveInput.HasAxes}">
                            <TextBlock Text="Axes"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       Opacity="0.75"/>
                            <ItemsControl ItemsSource="{Binding SelectedDeviceLiveInput.Axes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="inputviewer:AxisLiveViewModel">
                                        <Grid ColumnDefinitions="46,*"
                                              ColumnSpacing="6"
                                              Margin="0,2">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Label}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.8"/>
                                            <Grid Grid.Column="1"
                                                  Height="14"
                                                  ClipToBounds="True"
                                                  VerticalAlignment="Center">
                                                <Border Background="#252525" CornerRadius="2"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{Binding BarLeftWidth}"/>
                                                        <ColumnDefinition Width="{Binding BarFillWidth}"/>
                                                        <ColumnDefinition Width="{Binding BarRightWidth}"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="1" Background="#3B82F6" CornerRadius="1"/>
                                                </Grid>
                                                <Rectangle Width="1" HorizontalAlignment="Center" Fill="#555555"/>
                                                <TextBlock Text="{Binding ValueLabel}"
                                                           FontSize="8"
                                                           FontFamily="Consolas,Monospace"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="White"/>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Buttons -->
                        <StackPanel Spacing="6"
                                    IsVisible="{Binding SelectedDeviceLiveInput.HasButtons}">
                            <TextBlock Text="Buttons"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       Opacity="0.75"/>
                            <ItemsControl ItemsSource="{Binding SelectedDeviceLiveInput.Buttons}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="inputviewer:ButtonLiveViewModel">
                                        <Border Width="28"
                                                Height="28"
                                                CornerRadius="4"
                                                Margin="2"
                                                Classes.btn-pressed="{Binding IsPressed}"
                                                Classes.btn-released="{Binding !IsPressed}">
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="9"
                                                       FontFamily="Consolas,Monospace"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="White"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Hats -->
                        <StackPanel Spacing="6"
                                    IsVisible="{Binding SelectedDeviceLiveInput.HasHats}">
                            <TextBlock Text="Hats"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       Opacity="0.75"/>
                            <ItemsControl ItemsSource="{Binding SelectedDeviceLiveInput.Hats}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="inputviewer:HatLiveViewModel">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="10"
                                                    Margin="0,4">
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       MinWidth="40"
                                                       Opacity="0.8"/>
                                            <Grid RowDefinitions="20,20,20"
                                                  ColumnDefinitions="20,20,20">
                                                <Border Grid.Row="0" Grid.Column="0" CornerRadius="3" Margin="1"
                                                        Classes.hat-active="{Binding IsNorthWest}"
                                                        Classes.hat-inactive="{Binding !IsNorthWest}"/>
                                                <Border Grid.Row="0" Grid.Column="1" CornerRadius="3" Margin="1"
                                                        Classes.hat-active="{Binding IsNorth}"
                                                        Classes.hat-inactive="{Binding !IsNorth}"/>
                                                <Border Grid.Row="0" Grid.Column="2" CornerRadius="3" Margin="1"
                                                        Classes.hat-active="{Binding IsNorthEast}"
                                                        Classes.hat-inactive="{Binding !IsNorthEast}"/>
                                                <Border Grid.Row="1" Grid.Column="0" CornerRadius="3" Margin="1"
                                                        Classes.hat-active="{Binding IsWest}"
                                                        Classes.hat-inactive="{Binding !IsWest}"/>
                                                <Border Grid.Row="1" Grid.Column="1" CornerRadius="3" Margin="1"
                                                        Classes.hat-center-active="{Binding IsCenter}"
                                                        Classes.hat-inactive="{Binding !IsCenter}">
                                                    <TextBlock Text="●"
                                                               FontSize="8"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="White"/>
                                                </Border>
                                                <Border Grid.Row="1" Grid.Column="2" CornerRadius="3" Margin="1"
                                                        Classes.hat-active="{Binding IsEast}"
                                                        Classes.hat-inactive="{Binding !IsEast}"/>
                                                <Border Grid.Row="2" Grid.Column="0" CornerRadius="3" Margin="1"
                                                        Classes.hat-active="{Binding IsSouthWest}"
                                                        Classes.hat-inactive="{Binding !IsSouthWest}"/>
                                                <Border Grid.Row="2" Grid.Column="1" CornerRadius="3" Margin="1"
                                                        Classes.hat-active="{Binding IsSouth}"
                                                        Classes.hat-inactive="{Binding !IsSouth}"/>
                                                <Border Grid.Row="2" Grid.Column="2" CornerRadius="3" Margin="1"
                                                        Classes.hat-active="{Binding IsSouthEast}"
                                                        Classes.hat-inactive="{Binding !IsSouthEast}"/>
                                            </Grid>
                                            <TextBlock Text="{Binding DirectionLabel}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       MinWidth="32"
                                                       Opacity="0.8"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>

            <!-- ─── Row 1: Splitter ─── -->
            <GridSplitter Grid.Row="1"
                          Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"/>

            <!-- ─── Row 2: Binding editor (action list left, config right) ─── -->
            <Grid Grid.Row="2" ColumnDefinitions="*,6,*">

                <!-- Left: bound action list + toolbar -->
                <DockPanel Grid.Column="0">
                    <Border DockPanel.Dock="Top"
                            Padding="8,6"
                            BorderThickness="0,0,1,1"
                            BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Bindings"
                                       FontWeight="SemiBold"
                                       FontSize="13"/>
                            <TextBlock Text="{Binding SelectedInputRow.Label, FallbackValue='Select an input row'}"
                                       FontSize="11"
                                       Opacity="0.65"/>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Top"
                            Padding="6,4"
                            BorderThickness="0,0,1,1"
                            BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                        <StackPanel Spacing="4">
                            <!-- Row 1: Action type selector -->
                            <ComboBox ItemsSource="{Binding BindingEditor.AvailableActionTypes}"
                                      SelectedItem="{Binding BindingEditor.SelectedNewActionType}"
                                      HorizontalAlignment="Stretch"
                                      IsEnabled="{Binding BindingEditor.HasProfile}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="actions:IActionDescriptor">
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <!-- Row 2: Action management buttons -->
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <Button Content="+ Add"
                                        Command="{Binding BindingEditor.AddActionCommand}"
                                        FontSize="12"/>
                                <Button Content="− Remove"
                                        Command="{Binding BindingEditor.RemoveActionCommand}"
                                        FontSize="12"/>
                                <Button Content="▲"
                                        Command="{Binding BindingEditor.MoveUpCommand}"
                                        FontSize="12"
                                        ToolTip.Tip="Move action up"/>
                                <Button Content="▼"
                                        Command="{Binding BindingEditor.MoveDownCommand}"
                                        FontSize="12"
                                        ToolTip.Tip="Move action down"/>
                                <Button Content="💾 Save"
                                        Command="{Binding SaveBindingChangesCommand}"
                                        FontSize="12"
                                        ToolTip.Tip="Save binding changes to profile"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <ListBox ItemsSource="{Binding BindingEditor.BoundActions}"
                             SelectedItem="{Binding BindingEditor.SelectedBoundAction}"
                             BorderThickness="0,0,1,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:BoundActionViewModel">
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,3">
                                    <TextBlock Text="{Binding ActionName}"
                                               FontWeight="SemiBold"
                                               MinWidth="100"/>
                                    <TextBlock Text="{Binding ConfigSummary}"
                                               Opacity="0.6"
                                               FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <GridSplitter Grid.Column="1"
                              Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                              ResizeDirection="Columns"
                              ResizeBehavior="PreviousAndNext"
                              ShowsPreview="True"/>

                <!-- Right: configure action form -->
                <DockPanel Grid.Column="2">
                    <Border DockPanel.Dock="Top"
                            Padding="8,6"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                        <TextBlock Text="Configure Action"
                                   FontWeight="SemiBold"
                                   FontSize="13"/>
                    </Border>

                    <ScrollViewer>
                        <StackPanel Margin="12" Spacing="10">
                            <TextBlock Text="Select a binding to configure it."
                                       Opacity="0.5"
                                       IsVisible="{Binding !BindingEditor.ShowConfigPanel}"/>

                            <StackPanel Spacing="10" IsVisible="{Binding BindingEditor.ShowConfigPanel}">

                                <StackPanel Spacing="6" IsVisible="{Binding BindingEditor.ShowVJoyAxisConfig}">
                                    <TextBlock Text="vJoy Device ID"/>
                                    <NumericUpDown Value="{Binding BindingEditor.EditVJoyDeviceId}"
                                                  Minimum="1" Maximum="16"
                                                  FormatString="0"
                                                  Width="100" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Axis Index"/>
                                    <NumericUpDown Value="{Binding BindingEditor.EditVJoyAxisIndex}"
                                                  Minimum="1" Maximum="8"
                                                  FormatString="0"
                                                  Width="100" HorizontalAlignment="Left"/>
                                </StackPanel>

                                <StackPanel Spacing="6" IsVisible="{Binding BindingEditor.ShowVJoyButtonConfig}">
                                    <TextBlock Text="vJoy Device ID"/>
                                    <NumericUpDown Value="{Binding BindingEditor.EditVJoyDeviceId}"
                                                  Minimum="1" Maximum="16"
                                                  FormatString="0"
                                                  Width="100" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Button Index"/>
                                    <NumericUpDown Value="{Binding BindingEditor.EditVJoyButtonIndex}"
                                                  Minimum="1" Maximum="128"
                                                  FormatString="0"
                                                  Width="100" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Press Threshold (0 – 1)"/>
                                    <NumericUpDown Value="{Binding BindingEditor.EditVJoyButtonThreshold}"
                                                   Minimum="0" Maximum="1"
                                                   Increment="0.01"
                                                   FormatString="0.00"
                                                   Width="124" HorizontalAlignment="Left"/>
                                    <TextBlock Text="0.5 = half-travel (default) · 0.05 = hair-trigger · 0.9 = full-press"
                                               FontSize="10"
                                               Opacity="0.6"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="Changes are staged until you click Save Changes."
                                               FontSize="10"
                                               Opacity="0.6"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Spacing="6" IsVisible="{Binding BindingEditor.ShowVJoyHatConfig}">
                                    <TextBlock Text="vJoy Device ID"/>
                                    <NumericUpDown Value="{Binding BindingEditor.EditVJoyDeviceId}"
                                                  Minimum="1" Maximum="16"
                                                  FormatString="0"
                                                  Width="100" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Hat Index"/>
                                    <NumericUpDown Value="{Binding BindingEditor.EditVJoyHatIndex}"
                                                  Minimum="1" Maximum="4"
                                                  FormatString="0"
                                                  Width="100" HorizontalAlignment="Left"/>
                                </StackPanel>

                                <StackPanel Spacing="6" IsVisible="{Binding BindingEditor.ShowButtonsToHatConfig}">
                                    <TextBlock Text="Target vJoy Device ID"/>
                                    <NumericUpDown Value="{Binding BindingEditor.EditVJoyDeviceId}"
                                                  Minimum="1" Maximum="16"
                                                  FormatString="0"
                                                  Width="100" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Target Hat Index"/>
                                    <NumericUpDown Value="{Binding BindingEditor.EditVJoyHatIndex}"
                                                  Minimum="1" Maximum="4"
                                                  FormatString="0"
                                                  Width="100" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Directional source buttons"/>
                                    <Grid ColumnDefinitions="Auto,Auto"
                                          RowDefinitions="Auto,Auto,Auto,Auto"
                                          ColumnSpacing="12"
                                          RowSpacing="6">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Up"/>
                                        <NumericUpDown Grid.Row="0" Grid.Column="1"
                                                       Value="{Binding BindingEditor.EditDirectionalUpButtonId}"
                                                       Minimum="1" Maximum="128"
                                                       FormatString="0"
                                                       Width="100" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Down"/>
                                        <NumericUpDown Grid.Row="1" Grid.Column="1"
                                                       Value="{Binding BindingEditor.EditDirectionalDownButtonId}"
                                                       Minimum="1" Maximum="128"
                                                       FormatString="0"
                                                       Width="100" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Left"/>
                                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                                       Value="{Binding BindingEditor.EditDirectionalLeftButtonId}"
                                                       Minimum="1" Maximum="128"
                                                       FormatString="0"
                                                       Width="100" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Right"/>
                                        <NumericUpDown Grid.Row="3" Grid.Column="1"
                                                       Value="{Binding BindingEditor.EditDirectionalRightButtonId}"
                                                       Minimum="1" Maximum="128"
                                                       FormatString="0"
                                                       Width="100" HorizontalAlignment="Left"/>
                                    </Grid>
                                    <TextBlock TextWrapping="Wrap"
                                               FontSize="11"
                                               Opacity="0.65"
                                               Text="This mapping is mirrored onto each referenced source button in the current edit mode so all four buttons participate in the shared hat state."/>
                                </StackPanel>

                                <StackPanel Spacing="6" IsVisible="{Binding BindingEditor.ShowButtonsToAxesConfig}">
                                    <TextBlock Text="Target vJoy Device ID"/>
                                    <NumericUpDown Value="{Binding BindingEditor.EditVJoyDeviceId}"
                                                  Minimum="1" Maximum="16"
                                                  FormatString="0"
                                                  Width="100" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Target X Axis Index"/>
                                    <NumericUpDown Value="{Binding BindingEditor.EditButtonsToAxesXAxisIndex}"
                                                  Minimum="1" Maximum="8"
                                                  FormatString="0"
                                                  Width="100" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Target Y Axis Index"/>
                                    <NumericUpDown Value="{Binding BindingEditor.EditButtonsToAxesYAxisIndex}"
                                                  Minimum="1" Maximum="8"
                                                  FormatString="0"
                                                  Width="100" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Directional source buttons"/>
                                    <Grid ColumnDefinitions="Auto,Auto"
                                          RowDefinitions="Auto,Auto,Auto,Auto"
                                          ColumnSpacing="12"
                                          RowSpacing="6">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Up"/>
                                        <NumericUpDown Grid.Row="0" Grid.Column="1"
                                                       Value="{Binding BindingEditor.EditDirectionalUpButtonId}"
                                                       Minimum="1" Maximum="128"
                                                       FormatString="0"
                                                       Width="100" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Down"/>
                                        <NumericUpDown Grid.Row="1" Grid.Column="1"
                                                       Value="{Binding BindingEditor.EditDirectionalDownButtonId}"
                                                       Minimum="1" Maximum="128"
                                                       FormatString="0"
                                                       Width="100" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Left"/>
                                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                                       Value="{Binding BindingEditor.EditDirectionalLeftButtonId}"
                                                       Minimum="1" Maximum="128"
                                                       FormatString="0"
                                                       Width="100" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Right"/>
                                        <NumericUpDown Grid.Row="3" Grid.Column="1"
                                                       Value="{Binding BindingEditor.EditDirectionalRightButtonId}"
                                                       Minimum="1" Maximum="128"
                                                       FormatString="0"
                                                       Width="100" HorizontalAlignment="Left"/>
                                    </Grid>
                                    <TextBlock TextWrapping="Wrap"
                                               FontSize="11"
                                               Opacity="0.65"
                                               Text="This mapping is mirrored onto each referenced source button in the current edit mode so the shared X/Y axis state updates from every configured button."/>
                                </StackPanel>

                                <StackPanel Spacing="6" IsVisible="{Binding BindingEditor.ShowMacroConfig}">
                                    <TextBlock Text="Keys (comma-separated)"/>
                                    <TextBox Text="{Binding BindingEditor.EditMacroKeys}"
                                             PlaceholderText="e.g. LControl,C"
                                             Width="220"
                                             HorizontalAlignment="Left"/>
                                </StackPanel>

                                <StackPanel Spacing="6" IsVisible="{Binding BindingEditor.ShowMapToKeyboardConfig}">
                                    <TextBlock Text="Keys (comma-separated, modifiers first)"/>
                                    <TextBox Text="{Binding BindingEditor.EditMapToKeyboardKeys}"
                                             PlaceholderText="e.g. LShift,A"
                                             Width="220"
                                             HorizontalAlignment="Left"/>
                                    <TextBlock Text="Behavior"/>
                                    <ComboBox ItemsSource="{Binding MapToKeyboardBehaviors}"
                                              SelectedItem="{Binding BindingEditor.EditMapToKeyboardBehavior}"
                                              MinWidth="140"
                                              HorizontalAlignment="Left"/>
                                </StackPanel>

                                <StackPanel Spacing="6" IsVisible="{Binding BindingEditor.ShowHatToAxisConfig}">
                                    <TextBlock Text="Target vJoy Device ID"/>
                                    <NumericUpDown Value="{Binding BindingEditor.EditVJoyDeviceId}"
                                                  Minimum="1" Maximum="16"
                                                  FormatString="0"
                                                  Width="100" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Target X Axis Index (0 = disabled)"/>
                                    <NumericUpDown Value="{Binding BindingEditor.EditHatToAxisXAxisIndex}"
                                                  Minimum="0" Maximum="8"
                                                  FormatString="0"
                                                  Width="100" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Target Y Axis Index (0 = disabled)"/>
                                    <NumericUpDown Value="{Binding BindingEditor.EditHatToAxisYAxisIndex}"
                                                  Minimum="0" Maximum="8"
                                                  FormatString="0"
                                                  Width="100" HorizontalAlignment="Left"/>
                                    <TextBlock TextWrapping="Wrap"
                                               FontSize="11"
                                               Opacity="0.65"
                                               Text="Maps hat/POV direction to X/Y axis values. 0°=North(Y+), 90°=East(X+). Diagonals output ~0.707 on each axis. Set an index to 0 to disable that axis."/>
                                </StackPanel>

                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>

            </Grid>
        </Grid>
    </Grid>
</UserControl>
