<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="JoystickGremlin.App.Views.HidHideWarningDialog"
        Title="HidHide Not Installed"
        Width="500"
        MinWidth="400" MinHeight="220"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Border Padding="24">
        <StackPanel Spacing="16">

            <!-- Header row -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="⚠️" FontSize="32" VerticalAlignment="Center"/>
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="HidHide Not Installed"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="HidHide integration is enabled but the driver is not installed or is not operational."
                               FontSize="12"
                               Opacity="0.7"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>

            <!-- Info box -->
            <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    CornerRadius="4"
                    Padding="12,8">
                <TextBlock Text="HidHide is a Windows kernel driver that hides physical HID devices from selected applications. Install it and restart to use the HidHide integration, or disable it in Settings → HidHide."
                           FontSize="13"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Info note -->
            <TextBlock Text="The application will continue to run normally. Device hiding will be unavailable until HidHide is installed."
                       FontSize="11"
                       Opacity="0.6"
                       TextWrapping="Wrap"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button x:Name="DownloadButton"
                        Content="⬇  Download HidHide"
                        Click="DownloadButton_Click"/>
                <Button x:Name="ContinueButton"
                        Content="Continue Anyway"
                        Click="ContinueButton_Click"
                        IsDefault="True"/>
            </StackPanel>

        </StackPanel>
    </Border>

</Window>
