<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JoystickGremlin.App.ViewModels"
             xmlns:core="using:JoystickGremlin.Core.Profile"
             x:Class="JoystickGremlin.App.Views.AutoLoadPageView"
             x:DataType="vm:AutoLoadPageViewModel">

    <ScrollViewer>
        <StackPanel Margin="16" Spacing="14">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Auto-load Profiles" FontWeight="SemiBold" FontSize="18" VerticalAlignment="Center"/>
                <CheckBox Content="Enabled" IsChecked="{Binding EnableAutoLoading}" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock TextWrapping="Wrap" Opacity="0.65" FontSize="12" MaxWidth="720" HorizontalAlignment="Left">
                Triggers map an application to the profile that should load when that application
                becomes the active (focused) window. The pipeline starts on activation and stops when
                the application leaves the foreground (the profile stays loaded). Triggers are checked
                top to bottom — the first enabled match wins.
            </TextBlock>

            <!-- Legacy embedded-trigger migration banner -->
            <Border IsVisible="{Binding HasLegacyTriggers}"
                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    CornerRadius="4" Padding="10" MaxWidth="720" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="⚠" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LegacyBannerText}"
                               TextWrapping="Wrap" FontSize="12" VerticalAlignment="Center"/>
                    <Button Content="Migrate now"
                            Command="{Binding MigrateLegacyCommand}"
                            FontSize="12" VerticalAlignment="Center"
                            ToolTip.Tip="Import the embedded triggers into the global list below and remove them from the profile files"/>
                </StackPanel>
            </Border>

            <!-- Result of the last manual migration -->
            <TextBlock Text="{Binding MigrationStatusMessage}"
                       IsVisible="{Binding MigrationStatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                       TextWrapping="Wrap" Opacity="0.65" FontSize="11"
                       MaxWidth="720" HorizontalAlignment="Left"/>

            <TextBlock TextWrapping="Wrap" Opacity="0.55" FontSize="11" MaxWidth="720" HorizontalAlignment="Left"
                       IsVisible="{Binding !Triggers.Count}">
                No triggers configured. Click "+ Add Trigger", pick a profile, then choose the
                application that should activate it.
            </TextBlock>

            <!-- Column header -->
            <Grid ColumnDefinitions="200,*,46,72,78,90"
                  IsVisible="{Binding Triggers.Count}">
                <TextBlock Grid.Column="0" Text="Profile"      FontSize="11" FontWeight="SemiBold" Margin="2,0"/>
                <TextBlock Grid.Column="1" Text="Application"  FontSize="11" FontWeight="SemiBold" Margin="2,0"/>
                <TextBlock Grid.Column="2" Text="On"           FontSize="11" FontWeight="SemiBold" Margin="2,0" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="AutoStart"    FontSize="11" FontWeight="SemiBold" Margin="2,0" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="Stay Active"  FontSize="11" FontWeight="SemiBold" Margin="2,0" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="5" Text="Actions"      FontSize="11" FontWeight="SemiBold" Margin="2,0" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Trigger rows -->
            <ItemsControl ItemsSource="{Binding Triggers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProcessTriggerViewModel">
                        <Grid ColumnDefinitions="200,*,46,72,78,90" Margin="0,3">

                            <!-- Profile cell -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" Margin="2,0">
                                <ComboBox ItemsSource="{Binding $parent[ItemsControl].((vm:AutoLoadPageViewModel)DataContext).AvailableProfiles}"
                                          SelectedItem="{Binding SelectedProfile}"
                                          PlaceholderText="(select profile)"
                                          ToolTip.Tip="{Binding ProfileTooltip}"
                                          FontSize="11" MinWidth="160" MaxWidth="170"
                                          VerticalAlignment="Center">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="core:ProfileEntry">
                                            <TextBlock Text="{Binding DisplayLabel}" FontSize="11"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="⚠"
                                           IsVisible="{Binding IsProfileUnresolved}"
                                           ToolTip.Tip="{Binding ProfileTooltip}"
                                           FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Application (match) cell -->
                            <Grid Grid.Column="1" ColumnDefinitions="Auto,*,28,28" Margin="2,0" ColumnSpacing="2">
                                <Border Grid.Column="0"
                                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                        CornerRadius="3" Padding="4,1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding MatchModeLabel}" FontSize="10" Opacity="0.7"/>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding MatchDisplay}"
                                           ToolTip.Tip="{Binding MatchTooltip}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="4,0"/>
                                <Button Grid.Column="2"
                                        Content="🎯"
                                        Command="{Binding PickProcessCommand}"
                                        FontSize="11" Padding="2,0"
                                        ToolTip.Tip="Pick a running process (match by name)"/>
                                <Button Grid.Column="3"
                                        Content="📁"
                                        Command="{Binding BrowseExecutableCommand}"
                                        FontSize="11" Padding="2,0"
                                        ToolTip.Tip="Browse for an executable (match by full path)"/>
                            </Grid>

                            <!-- IsEnabled -->
                            <CheckBox Grid.Column="2"
                                      IsChecked="{Binding IsEnabled}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            <!-- AutoStart -->
                            <CheckBox Grid.Column="3"
                                      IsChecked="{Binding AutoStart}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      ToolTip.Tip="Start the input pipeline automatically when this trigger activates"/>
                            <!-- RemainActiveOnFocusLoss -->
                            <CheckBox Grid.Column="4"
                                      IsChecked="{Binding RemainActiveOnFocusLoss}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      ToolTip.Tip="Keep the pipeline running even when this application loses focus"/>
                            <!-- Actions: ↑ ↓ 🗑 -->
                            <StackPanel Grid.Column="5"
                                        Orientation="Horizontal"
                                        Spacing="2"
                                        HorizontalAlignment="Center">
                                <Button Content="↑"
                                        Command="{Binding $parent[ItemsControl].((vm:AutoLoadPageViewModel)DataContext).MoveUpCommand}"
                                        CommandParameter="{Binding}"
                                        FontSize="11" Padding="4,2"
                                        ToolTip.Tip="Move up (higher priority)"/>
                                <Button Content="↓"
                                        Command="{Binding $parent[ItemsControl].((vm:AutoLoadPageViewModel)DataContext).MoveDownCommand}"
                                        CommandParameter="{Binding}"
                                        FontSize="11" Padding="4,2"
                                        ToolTip.Tip="Move down (lower priority)"/>
                                <Button Content="🗑"
                                        Command="{Binding $parent[ItemsControl].((vm:AutoLoadPageViewModel)DataContext).RemoveTriggerCommand}"
                                        CommandParameter="{Binding}"
                                        FontSize="11" Padding="4,2"
                                        ToolTip.Tip="Remove this trigger"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="+ Add Trigger"
                    Command="{Binding AddTriggerCommand}"
                    FontSize="12"
                    HorizontalAlignment="Left"/>

        </StackPanel>
    </ScrollViewer>

</UserControl>
