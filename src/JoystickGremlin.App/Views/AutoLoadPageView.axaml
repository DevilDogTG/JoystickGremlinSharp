<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JoystickGremlin.App.ViewModels"
             x:Class="JoystickGremlin.App.Views.AutoLoadPageView"
             x:DataType="vm:AutoLoadPageViewModel">

    <ScrollViewer>
        <StackPanel Margin="16" Spacing="14">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Auto-load Profiles" FontWeight="SemiBold" FontSize="18" VerticalAlignment="Center"/>
                <CheckBox Content="Enabled" IsChecked="{Binding EnableAutoLoading}" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock TextWrapping="Wrap" Opacity="0.65" FontSize="12" MaxWidth="720" HorizontalAlignment="Left">
                When a mapped application becomes the active (focused) window, its profile is loaded and
                the mapping starts. Switching to another window stops the mapping (the profile stays loaded)
                and refocusing the application resumes it. The first enabled match in the list wins.
            </TextBlock>

            <!-- Column header -->
            <Grid ColumnDefinitions="2*,2*,46,72,78,90"
                  IsVisible="{Binding Mappings.Count}">
                <TextBlock Grid.Column="0" Text="Application"   FontSize="11" FontWeight="SemiBold" Margin="2,0"/>
                <TextBlock Grid.Column="1" Text="Profile"       FontSize="11" FontWeight="SemiBold" Margin="2,0"/>
                <TextBlock Grid.Column="2" Text="On"            FontSize="11" FontWeight="SemiBold" Margin="2,0" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="AutoStart"     FontSize="11" FontWeight="SemiBold" Margin="2,0" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="Stay Active"   FontSize="11" FontWeight="SemiBold" Margin="2,0" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="5" Text="Actions"       FontSize="11" FontWeight="SemiBold" Margin="2,0" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Mapping rows -->
            <ItemsControl ItemsSource="{Binding Mappings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProcessMappingViewModel">
                        <Grid ColumnDefinitions="2*,2*,46,72,78,90" Margin="0,3">

                            <!-- Application (match) cell -->
                            <Grid Grid.Column="0" ColumnDefinitions="Auto,*,28,28" Margin="2,0" ColumnSpacing="2">
                                <Border Grid.Column="0"
                                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                        CornerRadius="3" Padding="4,1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding MatchModeLabel}" FontSize="10" Opacity="0.7"/>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding MatchDisplay}"
                                           ToolTip.Tip="{Binding MatchTooltip}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="4,0"/>
                                <Button Grid.Column="2"
                                        Content="🎯"
                                        Command="{Binding PickProcessCommand}"
                                        FontSize="11" Padding="2,0"
                                        ToolTip.Tip="Pick a running process (match by name)"/>
                                <Button Grid.Column="3"
                                        Content="📁"
                                        Command="{Binding BrowseExecutableCommand}"
                                        FontSize="11" Padding="2,0"
                                        ToolTip.Tip="Browse for an executable (match by full path)"/>
                            </Grid>

                            <!-- Profile cell -->
                            <Grid Grid.Column="1" Margin="2,0">
                                <ComboBox HorizontalAlignment="Stretch"
                                          FontSize="11"
                                          PlaceholderText="(select profile)"
                                          ItemsSource="{Binding $parent[ItemsControl].((vm:AutoLoadPageViewModel)DataContext).AvailableProfiles}"
                                          SelectedItem="{Binding SelectedProfile}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayLabel}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="⚠ missing"
                                           FontSize="10"
                                           Foreground="{StaticResource WarningForegroundBrush}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="0,0,30,0"
                                           IsVisible="{Binding IsProfileMissing}"
                                           ToolTip.Tip="The previously selected profile no longer exists. Choose another."/>
                            </Grid>

                            <!-- IsEnabled -->
                            <CheckBox Grid.Column="2"
                                      IsChecked="{Binding IsEnabled}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            <!-- AutoStart -->
                            <CheckBox Grid.Column="3"
                                      IsChecked="{Binding AutoStart}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      ToolTip.Tip="Start the input pipeline automatically when this mapping activates"/>
                            <!-- RemainActiveOnFocusLoss -->
                            <CheckBox Grid.Column="4"
                                      IsChecked="{Binding RemainActiveOnFocusLoss}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      ToolTip.Tip="Keep the pipeline running even when this application loses focus"/>
                            <!-- Actions: ↑ ↓ 🗑 -->
                            <StackPanel Grid.Column="5"
                                        Orientation="Horizontal"
                                        Spacing="2"
                                        HorizontalAlignment="Center">
                                <Button Content="↑"
                                        Command="{Binding $parent[ItemsControl].((vm:AutoLoadPageViewModel)DataContext).MoveUpCommand}"
                                        CommandParameter="{Binding}"
                                        FontSize="11" Padding="4,2"
                                        ToolTip.Tip="Move up (higher priority)"/>
                                <Button Content="↓"
                                        Command="{Binding $parent[ItemsControl].((vm:AutoLoadPageViewModel)DataContext).MoveDownCommand}"
                                        CommandParameter="{Binding}"
                                        FontSize="11" Padding="4,2"
                                        ToolTip.Tip="Move down (lower priority)"/>
                                <Button Content="🗑"
                                        Command="{Binding $parent[ItemsControl].((vm:AutoLoadPageViewModel)DataContext).RemoveMappingCommand}"
                                        CommandParameter="{Binding}"
                                        FontSize="11" Padding="4,2"
                                        ToolTip.Tip="Remove this mapping"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="+ Add Mapping"
                    Command="{Binding AddMappingCommand}"
                    FontSize="12"
                    HorizontalAlignment="Left"/>

        </StackPanel>
    </ScrollViewer>

</UserControl>
