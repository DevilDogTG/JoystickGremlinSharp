<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="JoystickGremlin.App.Views.VJoyWarningDialog"
        Title="vJoy Prerequisite Required"
        Width="500" Height="260"
        MinWidth="400" MinHeight="220"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Border Padding="24">
        <StackPanel Spacing="16">

            <!-- Header row -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="⚠️" FontSize="32" VerticalAlignment="Center"/>
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="vJoy Prerequisite Required"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="JoystickGremlinSharp requires the BrunnerInnovation vJoy fork v2.2.x or later."
                               FontSize="12"
                               Opacity="0.7"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>

            <!-- Reason box -->
            <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    CornerRadius="4"
                    Padding="12,8">
                <TextBlock x:Name="ReasonText"
                           FontSize="13"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Info note -->
            <TextBlock Text="You can continue without vJoy, but output mappings will not work."
                       FontSize="11"
                       Opacity="0.6"
                       TextWrapping="Wrap"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button x:Name="DownloadButton"
                        Content="⬇  Download vJoy"
                        Click="DownloadButton_Click"/>
                <Button x:Name="ContinueButton"
                        Content="Continue Anyway"
                        Click="ContinueButton_Click"
                        IsDefault="True"/>
            </StackPanel>

        </StackPanel>
    </Border>

</Window>
